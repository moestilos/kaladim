# Base de datos Neon Postgres
DATABASE_URL=postgres://usuario:password@host.neon.tech/kaladim?sslmode=require

# Auth.js
AUTH_SECRET=genera_con_openssl_rand_base64_32
AUTH_TRUST_HOST=true

# Google OAuth (crear credenciales en https://console.cloud.google.com)
GOOGLE_CLIENT_ID=tu_google_client_id
GOOGLE_CLIENT_SECRET=tu_google_client_secret

# Admins separados por coma (emails con acceso al panel)
ADMIN_EMAILS=tu_email@gmail.com
