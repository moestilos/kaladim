---
import '../estilos/global.css';
import Logo from '../componentes/ui/Logo.astro';
import FondoConstelacion from '../componentes/ui/FondoConstelacion.astro';
import GestorTema from '../componentes/ui/GestorTema.astro';
import PaletaComandos from '../componentes/ui/PaletaComandos.astro';

interface Props {
  titulo?: string;
  descripcion?: string;
  imagen?: string;
}
const {
  titulo = 'Kaladim — Webs profesionales y automatizaciones con n8n para empresas',
  descripcion = 'Agencia digital especializada en desarrollo web de alto rendimiento y automatizaciones empresariales con n8n. Escalamos tu negocio con tecnología.',
  imagen = '/og-image.png',
} = Astro.props;

const url = Astro.url.href;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <GestorTema />

    <title>{titulo}</title>
    <meta name="description" content={descripcion} />
    <meta name="theme-color" content="#09090B" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={url} />
    <meta property="og:title" content={titulo} />
    <meta property="og:description" content={descripcion} />
    <meta property="og:image" content={imagen} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={titulo} />
    <meta name="twitter:description" content={descripcion} />
    <meta name="twitter:image" content={imagen} />

    <link rel="canonical" href={url} />
  </head>
  <body class="min-h-screen flex flex-col relative">
    <FondoConstelacion />

    <!-- ═════════ NAVEGACIÓN (pill flotante con indicador animado) ═════════ -->
    <header id="header-nav" class="fixed top-4 inset-x-0 z-50 flex justify-center px-3 sm:px-4 pointer-events-none transition-all duration-300">
      <div id="pill-nav" class="pointer-events-auto flex items-center gap-1 p-1.5 rounded-full border border-carbon-700/80 bg-carbon-900/80 backdrop-blur-xl shadow-2xl shadow-black/40 max-w-full transition-all duration-300 hover:border-violeta-500/40 hover:shadow-violeta-600/20">

        <!-- Logo (constelación K — sigue tema vía text-violeta-*) -->
        <a href="/" class="flex items-center gap-2 pl-1.5 pr-3 py-1 group shrink-0" aria-label="Kaladim — inicio">
          <svg viewBox="0 0 24 24" class="h-7 w-7 shrink-0 text-violeta-400 transition-all duration-200 group-hover:text-violeta-300 group-hover:scale-110"
            fill="none" aria-hidden="true">
            <g stroke="currentColor" stroke-width="1.1" stroke-linecap="round" opacity="0.6">
              <line x1="6"  y1="4"  x2="6"  y2="12"/>
              <line x1="6"  y1="12" x2="6"  y2="20"/>
              <line x1="6"  y1="12" x2="17" y2="4"/>
              <line x1="6"  y1="12" x2="17" y2="20"/>
            </g>
            <g fill="currentColor">
              <circle cx="6"  cy="4"  r="1.4"/>
              <circle cx="6"  cy="20" r="1.4"/>
              <circle cx="17" cy="4"  r="1.4"/>
              <circle cx="17" cy="20" r="1.4"/>
            </g>
            <circle cx="6" cy="12" r="2.2" fill="currentColor"/>
            <circle cx="6" cy="12" r="3" fill="none" stroke="currentColor" stroke-width="0.6" opacity="0.5">
              <animate attributeName="r" values="2.5;5;2.5" dur="2.6s" repeatCount="indefinite"/>
              <animate attributeName="opacity" values="0.5;0;0.5" dur="2.6s" repeatCount="indefinite"/>
            </circle>
          </svg>
          <span class="font-display font-semibold text-white text-[15px] tracking-[-0.025em] leading-none">Kaladim</span>
        </a>

        <span class="hidden lg:block w-px h-5 bg-carbon-700/80"></span>

        <!-- Enlaces (solo lg+) — con indicador deslizante -->
        <nav id="nav-links" class="hidden lg:flex items-center relative">
          <!-- Indicador animado (se mueve al link hovered/activo) -->
          <span id="nav-indicador"
            class="absolute top-1/2 -translate-y-1/2 h-8 rounded-full bg-violeta-500/15 border border-violeta-500/30 transition-all duration-300 ease-out opacity-0 pointer-events-none">
          </span>
          <a href="/#servicios" data-seccion="servicios" class="link-nav relative z-10 px-3 py-1.5 text-sm text-carbon-300 hover:text-white transition-colors rounded-full">servicios</a>
          <a href="/#casos" data-seccion="casos" class="link-nav relative z-10 px-3 py-1.5 text-sm text-carbon-300 hover:text-white transition-colors rounded-full">casos</a>
          <a href="/#automatizaciones" data-seccion="automatizaciones" class="link-nav relative z-10 px-3 py-1.5 text-sm text-carbon-300 hover:text-white transition-colors rounded-full">automatizaciones</a>
          <a href="/#proceso" data-seccion="proceso" class="link-nav relative z-10 px-3 py-1.5 text-sm text-carbon-300 hover:text-white transition-colors rounded-full">proceso</a>
          <a href="/#contacto" data-seccion="contacto" class="link-nav relative z-10 px-3 py-1.5 text-sm text-carbon-300 hover:text-white transition-colors rounded-full">contacto</a>
        </nav>

        <span class="hidden lg:block w-px h-5 bg-carbon-700/80"></span>

        <!-- Menú — abre paleta (en móvil funciona como menú completo) -->
        <button
          type="button"
          id="btn-abrir-paleta-nav"
          class="flex items-center gap-2 pl-3 pr-2 py-1.5 rounded-full bg-carbon-800/70 hover:bg-carbon-800 border border-carbon-700/60 text-sm text-carbon-200 hover:text-white transition-colors shrink-0"
        >
          <svg class="h-4 w-4 lg:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 6h16M4 12h16M4 18h16" stroke-linecap="round"/>
          </svg>
          <span class="hidden sm:inline">Menú</span>
          <kbd class="hidden sm:flex items-center gap-0.5 text-[10px] font-mono px-1.5 py-0.5 rounded bg-carbon-950/70 border border-carbon-700 text-carbon-400">
            <span class="text-[11px]">⌘</span>K
          </kbd>
        </button>
      </div>
    </header>

    <div class="h-20" aria-hidden="true"></div>

    <script>
      // ── Botón menú abre paleta ──
      document.getElementById('btn-abrir-paleta-nav')?.addEventListener('click', () => {
        document.getElementById('btn-abrir-paleta')?.click();
      });

      // ── Indicador deslizante hover/activo ──
      const navLinks = document.querySelectorAll<HTMLAnchorElement>('#nav-links .link-nav');
      const indicador = document.getElementById('nav-indicador') as HTMLSpanElement | null;
      const navContainer = document.getElementById('nav-links');
      let activoActual: HTMLAnchorElement | null = null;

      function moverIndicador(target: HTMLElement | null) {
        if (!indicador || !navContainer || !target) {
          if (indicador) indicador.style.opacity = '0';
          return;
        }
        const cont = navContainer.getBoundingClientRect();
        const r = target.getBoundingClientRect();
        indicador.style.width = r.width + 'px';
        indicador.style.left = (r.left - cont.left) + 'px';
        indicador.style.opacity = '1';
      }

      navLinks.forEach((a) => {
        a.addEventListener('mouseenter', () => moverIndicador(a));
      });
      navContainer?.addEventListener('mouseleave', () => moverIndicador(activoActual));

      // ── Scroll-spy: detecta sección activa ──
      const secciones = ['servicios', 'casos', 'automatizaciones', 'proceso', 'contacto']
        .map((id) => document.getElementById(id))
        .filter((el): el is HTMLElement => !!el);

      const observer = new IntersectionObserver((entries) => {
        // Toma la sección más visible
        const visibles = entries.filter((e) => e.isIntersecting);
        if (visibles.length === 0) return;
        const top = visibles.sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
        const id = top.target.id;
        const link = document.querySelector<HTMLAnchorElement>(`.link-nav[data-seccion="${id}"]`);
        navLinks.forEach((l) => l.classList.toggle('text-white', l === link));
        navLinks.forEach((l) => l.classList.toggle('text-carbon-300', l !== link));
        activoActual = link;
        moverIndicador(link);
      }, { rootMargin: '-40% 0px -55% 0px', threshold: [0, 0.25, 0.5, 0.75, 1] });

      secciones.forEach((s) => observer.observe(s));

      // Click → fija activo
      navLinks.forEach((a) => {
        a.addEventListener('click', () => {
          activoActual = a;
          setTimeout(() => moverIndicador(a), 50);
        });
      });

      // ── Pill morph al scrollear ──
      const header = document.getElementById('header-nav');
      const pill = document.getElementById('pill-nav');
      let ultimoScroll = 0;
      function actualizarPill() {
        const y = window.scrollY;
        if (!header || !pill) return;
        if (y > 30) {
          header.classList.add('top-2');
          header.classList.remove('top-4');
          pill.classList.add('shadow-violeta-600/30', 'border-carbon-600/80');
          pill.classList.remove('border-carbon-700/80');
        } else {
          header.classList.remove('top-2');
          header.classList.add('top-4');
          pill.classList.remove('shadow-violeta-600/30', 'border-carbon-600/80');
          pill.classList.add('border-carbon-700/80');
        }
        ultimoScroll = y;
      }
      window.addEventListener('scroll', actualizarPill, { passive: true });
      actualizarPill();

      // Recalcular indicador en resize
      window.addEventListener('resize', () => moverIndicador(activoActual));
    </script>

    <main class="flex-1 relative z-10"><slot /></main>

    <PaletaComandos />

    <!-- ═════════ FOOTER ═════════ -->
    <footer class="relative z-10 border-t border-carbon-800/50 bg-carbon-950">
      <div class="contenedor py-16 grid gap-10 md:grid-cols-4">
        <div class="md:col-span-2">
          <Logo />
          <p class="mt-4 text-sm text-carbon-400 max-w-sm">
            Agencia digital enfocada en webs de alto rendimiento y automatizaciones empresariales con n8n. Construimos herramientas que trabajan por ti.
          </p>
        </div>
        <div>
          <h4 class="text-sm font-semibold text-white mb-4">Servicios</h4>
          <ul class="space-y-2 text-sm text-carbon-400">
            <li><a href="/#servicios" class="hover:text-violeta-400">Webs corporativas</a></li>
            <li><a href="/#servicios" class="hover:text-violeta-400">E-commerce</a></li>
            <li><a href="/#automatizaciones" class="hover:text-violeta-400">Automatizaciones n8n</a></li>
            <li><a href="/#servicios" class="hover:text-violeta-400">Integraciones API</a></li>
          </ul>
        </div>
        <div>
          <h4 class="text-sm font-semibold text-white mb-4">Empresa</h4>
          <ul class="space-y-2 text-sm text-carbon-400">
            <li><a href="/#proceso" class="hover:text-violeta-400">Cómo trabajamos</a></li>
            <li><a href="/#contacto" class="hover:text-violeta-400">Contacto</a></li>
            <li><a href="/entrar" class="hover:text-violeta-400">Acceso clientes</a></li>
          </ul>
        </div>
      </div>
      <div class="border-t border-carbon-900">
        <div class="contenedor py-6 flex flex-col sm:flex-row justify-between items-center gap-3 text-xs text-carbon-500">
          <span>© {new Date().getFullYear()} Kaladim. Todos los derechos reservados.</span>
          <span>Hecho con Astro, Tailwind y mucho café ☕</span>
        </div>
      </div>
    </footer>
  </body>
</html>
