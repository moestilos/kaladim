---
// Fondo animado: red de partículas tipo constelación.
// Canvas fijo detrás del contenido. Respeta prefers-reduced-motion.
interface Props {
  densidad?: number; // partículas por millón de px² (default 80)
  distanciaConexion?: number; // px
}
const {
  densidad = 80,
  distanciaConexion = 140,
} = Astro.props;
---

<canvas
  id="lienzo-constelacion"
  class="fixed inset-0 z-0 pointer-events-none"
  data-densidad={densidad}
  data-distancia={distanciaConexion}
></canvas>

<!-- Máscara radial encima del canvas para desvanecer bordes -->
<div
  class="fixed inset-0 z-0 pointer-events-none"
  style="background: radial-gradient(ellipse 120% 100% at 50% 40%, transparent 60%, rgba(9,9,11,0.85) 100%);"
></div>

<script>
  const lienzo = document.getElementById('lienzo-constelacion') as HTMLCanvasElement | null;
  if (lienzo) {
    const ctx = lienzo.getContext('2d')!;
    const densidad = Number(lienzo.dataset.densidad);
    const distanciaConexion = Number(lienzo.dataset.distancia);

    // Lee color del tema actual (variable CSS --acento-600)
    let color = '124, 58, 237';
    let colorClaro = '167, 139, 250';
    function refrescarColor() {
      const cs = getComputedStyle(document.documentElement);
      const c600 = cs.getPropertyValue('--acento-600').trim();
      const c400 = cs.getPropertyValue('--acento-400').trim();
      if (c600) color = c600.replace(/\s+/g, ', ');
      if (c400) colorClaro = c400.replace(/\s+/g, ', ');
    }
    refrescarColor();
    // Re-lee cuando cambia tema (evento custom disparado por cambio)
    window.addEventListener('tema-cambiado', refrescarColor);

    const reducir = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    type Particula = {
      x: number; y: number;
      vx: number; vy: number;
      r: number;
      brillo: number;
      faseBrillo: number;
    };

    let particulas: Particula[] = [];
    let anchoDpr = 0, altoDpr = 0, dpr = 1;
    const mouse = { x: -9999, y: -9999, activo: false };

    function redimensionar() {
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      const ancho = window.innerWidth;
      const alto = window.innerHeight;
      lienzo!.width = ancho * dpr;
      lienzo!.height = alto * dpr;
      lienzo!.style.width = ancho + 'px';
      lienzo!.style.height = alto + 'px';
      anchoDpr = lienzo!.width;
      altoDpr = lienzo!.height;

      const cantidad = Math.min(
        180,
        Math.max(40, Math.floor((ancho * alto) / 1_000_000 * densidad)),
      );
      particulas = Array.from({ length: cantidad }, () => nueva());
    }

    function nueva(): Particula {
      return {
        x: Math.random() * anchoDpr,
        y: Math.random() * altoDpr,
        vx: (Math.random() - 0.5) * 0.15 * dpr,
        vy: (Math.random() - 0.5) * 0.15 * dpr,
        r: (Math.random() * 1.2 + 0.4) * dpr,
        brillo: Math.random(),
        faseBrillo: Math.random() * Math.PI * 2,
      };
    }

    function dibujar(t: number) {
      ctx.clearRect(0, 0, anchoDpr, altoDpr);

      const distMaxDpr = distanciaConexion * dpr;
      const distMaxSq = distMaxDpr * distMaxDpr;
      const radioMouse = 180 * dpr;

      // Mover y dibujar partículas
      for (const p of particulas) {
        if (!reducir) {
          p.x += p.vx;
          p.y += p.vy;
          p.faseBrillo += 0.015;

          // Rebote suave
          if (p.x < 0 || p.x > anchoDpr) p.vx *= -1;
          if (p.y < 0 || p.y > altoDpr) p.vy *= -1;

          // Atracción sutil hacia mouse
          if (mouse.activo) {
            const dx = mouse.x - p.x;
            const dy = mouse.y - p.y;
            const distSq = dx * dx + dy * dy;
            if (distSq < radioMouse * radioMouse && distSq > 100) {
              const fuerza = 0.0008;
              p.vx += (dx / Math.sqrt(distSq)) * fuerza * dpr;
              p.vy += (dy / Math.sqrt(distSq)) * fuerza * dpr;
            }
          }

          // Amortiguar velocidad
          p.vx *= 0.995;
          p.vy *= 0.995;
          // Mantener velocidad mínima
          const vel = Math.hypot(p.vx, p.vy);
          if (vel < 0.05 * dpr) {
            const ang = Math.random() * Math.PI * 2;
            p.vx += Math.cos(ang) * 0.05 * dpr;
            p.vy += Math.sin(ang) * 0.05 * dpr;
          }
        }

        const brillo = 0.4 + 0.4 * Math.sin(p.faseBrillo);
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${color}, ${0.5 + brillo * 0.4})`;
        ctx.fill();

        // Halo
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r * 2.5, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${color}, ${brillo * 0.08})`;
        ctx.fill();
      }

      // Líneas entre vecinas
      for (let i = 0; i < particulas.length; i++) {
        const a = particulas[i];
        for (let j = i + 1; j < particulas.length; j++) {
          const b = particulas[j];
          const dx = a.x - b.x;
          const dy = a.y - b.y;
          const distSq = dx * dx + dy * dy;
          if (distSq < distMaxSq) {
            const alpha = (1 - distSq / distMaxSq) * 0.35;
            ctx.beginPath();
            ctx.moveTo(a.x, a.y);
            ctx.lineTo(b.x, b.y);
            ctx.strokeStyle = `rgba(${color}, ${alpha})`;
            ctx.lineWidth = 0.6 * dpr;
            ctx.stroke();
          }
        }

        // Línea al cursor si está cerca
        if (mouse.activo) {
          const dx = a.x - mouse.x;
          const dy = a.y - mouse.y;
          const distSq = dx * dx + dy * dy;
          if (distSq < radioMouse * radioMouse) {
            const alpha = (1 - distSq / (radioMouse * radioMouse)) * 0.6;
            ctx.beginPath();
            ctx.moveTo(a.x, a.y);
            ctx.lineTo(mouse.x, mouse.y);
            ctx.strokeStyle = `rgba(${colorClaro}, ${alpha})`;
            ctx.lineWidth = 0.8 * dpr;
            ctx.stroke();
          }
        }
      }

      requestAnimationFrame(dibujar);
    }

    window.addEventListener('resize', redimensionar);
    window.addEventListener('mousemove', (e) => {
      mouse.x = e.clientX * dpr;
      mouse.y = e.clientY * dpr;
      mouse.activo = true;
    });
    window.addEventListener('mouseleave', () => { mouse.activo = false; });
    window.addEventListener('touchmove', (e) => {
      if (e.touches[0]) {
        mouse.x = e.touches[0].clientX * dpr;
        mouse.y = e.touches[0].clientY * dpr;
        mouse.activo = true;
      }
    }, { passive: true });
    window.addEventListener('touchend', () => { mouse.activo = false; });

    redimensionar();
    requestAnimationFrame(dibujar);
  }
</script>
