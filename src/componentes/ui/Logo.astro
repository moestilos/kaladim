---
// Logo Kaladim — K como grafo de nodos conectados.
// Mismo lenguaje visual que el fondo de constelación: puntos + líneas finas.
// Color via Tailwind violeta-400 → resuelve a var(--acento-*) → sigue tema.

interface Props {
  tamano?: 'xs' | 'sm' | 'md' | 'lg' | 'xl';
  mostrarTexto?: boolean;
  soloMarca?: boolean;
}
const { tamano = 'md', mostrarTexto = true, soloMarca = false } = Astro.props;

const medidas = {
  xs: { caja: 'h-5 w-5',  texto: 'text-sm'   },
  sm: { caja: 'h-6 w-6',  texto: 'text-base' },
  md: { caja: 'h-7 w-7',  texto: 'text-xl'   },
  lg: { caja: 'h-9 w-9',  texto: 'text-2xl' },
  xl: { caja: 'h-12 w-12', texto: 'text-3xl' },
};
const m = medidas[tamano];
const Wrapper = soloMarca ? 'div' : 'a';
const props = soloMarca ? {} : { href: '/', 'aria-label': 'Kaladim — inicio' };
---

<Wrapper {...props} class="flex items-center gap-2.5 group">
  <svg
    viewBox="0 0 24 24"
    class={`${m.caja} text-violeta-400 transition-all duration-200 group-hover:text-violeta-300 group-hover:scale-110`}
    fill="none"
    aria-hidden="true"
  >
    <!-- Líneas (constelación) -->
    <g stroke="currentColor" stroke-width="1.1" stroke-linecap="round" opacity="0.6">
      <line x1="6"  y1="4"  x2="6"  y2="12" />
      <line x1="6"  y1="12" x2="6"  y2="20" />
      <line x1="6"  y1="12" x2="17" y2="4"  />
      <line x1="6"  y1="12" x2="17" y2="20" />
    </g>

    <!-- Nodos extremos -->
    <g fill="currentColor">
      <circle cx="6"  cy="4"  r="1.4" />
      <circle cx="6"  cy="20" r="1.4" />
      <circle cx="17" cy="4"  r="1.4" />
      <circle cx="17" cy="20" r="1.4" />
    </g>

    <!-- Nodo central (junción) — más grande + pulsante -->
    <circle cx="6" cy="12" r="2.2" fill="currentColor" />
    <circle cx="6" cy="12" r="3" fill="none" stroke="currentColor" stroke-width="0.6" opacity="0.5">
      <animate attributeName="r" values="2.5;5;2.5" dur="2.6s" repeatCount="indefinite"/>
      <animate attributeName="opacity" values="0.5;0;0.5" dur="2.6s" repeatCount="indefinite"/>
    </circle>
  </svg>

  {mostrarTexto && (
    <span class={`${m.texto} font-display font-semibold tracking-[-0.025em] text-white leading-none`}>
      Kaladim
    </span>
  )}
</Wrapper>
