---
// Logo Kaladim — minimalista profesional.
// Fijo en violeta (#7C3AED) como identidad de marca — no cambia con el tema.
// Mismo glifo exacto que el favicon pa' consistencia visual total.

interface Props {
  tamano?: 'xs' | 'sm' | 'md' | 'lg' | 'xl';
  mostrarTexto?: boolean;
  soloMarca?: boolean;
}
const { tamano = 'md', mostrarTexto = true, soloMarca = false } = Astro.props;

const medidas = {
  xs: { caja: 'h-6 w-6',  texto: 'text-sm'   },
  sm: { caja: 'h-7 w-7',  texto: 'text-base' },
  md: { caja: 'h-8 w-8',  texto: 'text-xl'   },
  lg: { caja: 'h-10 w-10', texto: 'text-2xl' },
  xl: { caja: 'h-14 w-14', texto: 'text-3xl' },
};
const m = medidas[tamano];
const Wrapper = soloMarca ? 'div' : 'a';
const props = soloMarca ? {} : { href: '/', 'aria-label': 'Kaladim — inicio' };
---

<Wrapper {...props} class="flex items-center gap-2.5 group">
  <!-- Marca (color fijo brand) -->
  <span
    class={`${m.caja} relative grid place-items-center shrink-0 rounded-lg transition-transform duration-200 group-hover:scale-105`}
    style="background: #7C3AED;"
  >
    <svg viewBox="0 0 32 32" class="h-full w-full" aria-hidden="true">
      <rect width="32" height="32" rx="7" fill="#7C3AED"/>
      <path
        d="M11.5 8 V24 M11.5 16 L20 8 M11.5 16 L20 24"
        stroke="#ffffff"
        stroke-width="3"
        stroke-linecap="round"
        stroke-linejoin="round"
        fill="none"
      />
    </svg>
  </span>

  <!-- Wordmark -->
  {mostrarTexto && (
    <span class={`${m.texto} font-display font-semibold tracking-[-0.02em] text-white leading-none`}>
      Kaladim
    </span>
  )}
</Wrapper>
