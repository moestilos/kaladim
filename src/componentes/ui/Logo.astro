---
// Logo Kaladim — line-art a juego con iconos sidebar.
// Outline square + K monograma + nodo en junción. Stroke 1.8, mismo lenguaje visual.

interface Props {
  tamano?: 'xs' | 'sm' | 'md' | 'lg' | 'xl';
  mostrarTexto?: boolean;
  soloMarca?: boolean;
}
const { tamano = 'md', mostrarTexto = true, soloMarca = false } = Astro.props;

const medidas = {
  xs: { caja: 'h-5 w-5',  texto: 'text-sm'   },
  sm: { caja: 'h-6 w-6',  texto: 'text-base' },
  md: { caja: 'h-7 w-7',  texto: 'text-xl'   },
  lg: { caja: 'h-9 w-9',  texto: 'text-2xl' },
  xl: { caja: 'h-12 w-12', texto: 'text-3xl' },
};
const m = medidas[tamano];
const Wrapper = soloMarca ? 'div' : 'a';
const props = soloMarca ? {} : { href: '/', 'aria-label': 'Kaladim — inicio' };
---

<Wrapper {...props} class="flex items-center gap-2.5 group">
  <svg
    viewBox="0 0 24 24"
    class={`${m.caja} text-violeta-400 transition-transform duration-200 group-hover:scale-110 group-hover:text-violeta-300`}
    fill="none"
    stroke="currentColor"
    stroke-width="1.8"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <rect x="3" y="3" width="18" height="18" rx="4" />
    <path d="M9 7 V17" />
    <path d="M9 12 L15 7" />
    <path d="M9 12 L15 17" />
    <circle cx="9" cy="12" r="1.4" fill="currentColor" stroke="none" />
  </svg>

  {mostrarTexto && (
    <span class={`${m.texto} font-display font-semibold tracking-[-0.025em] text-white leading-none`}>
      Kaladim
    </span>
  )}
</Wrapper>
