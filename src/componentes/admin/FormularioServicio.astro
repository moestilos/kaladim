---
import { db, esquema } from '../../lib/db/cliente';
import { desc } from 'drizzle-orm';

interface Servicio {
  id?: string;
  proyectoId?: string;
  tipo?: string;
  nombre?: string;
  descripcion?: string | null;
  precio?: string;
  recurrente?: boolean;
  periodoMeses?: number | null;
}
interface Props {
  servicio?: Servicio;
  modo: 'crear' | 'editar';
}
const { servicio, modo } = Astro.props;
const accion = modo === 'crear' ? '/api/servicios' : `/api/servicios/${servicio?.id}`;
const metodo = modo === 'crear' ? 'POST' : 'PATCH';

let proyectos: { id: string; titulo: string }[] = [];
try {
  if (import.meta.env.DATABASE_URL) {
    proyectos = await db
      .select({ id: esquema.proyectos.id, titulo: esquema.proyectos.titulo })
      .from(esquema.proyectos)
      .orderBy(desc(esquema.proyectos.creadoEn));
  }
} catch (e) { console.error('[FormularioServicio] error proyectos', e); }

const tipos = [
  { v: 'web_landing',         l: 'Landing page' },
  { v: 'web_corporativa',     l: 'Web corporativa' },
  { v: 'web_ecommerce',       l: 'E-commerce' },
  { v: 'automatizacion_n8n',  l: 'Automatización n8n' },
  { v: 'integracion_api',     l: 'Integración API' },
  { v: 'mantenimiento',       l: 'Mantenimiento' },
  { v: 'consultoria',         l: 'Consultoría' },
];
---

<form id="formulario-servicio" class="tarjeta p-6 sm:p-8 max-w-3xl space-y-5" data-accion={accion} data-metodo={metodo}>
  <div>
    <label class="etiqueta" for="proyectoId">Proyecto *</label>
    <select id="proyectoId" name="proyectoId" required class="input">
      <option value="">— Selecciona proyecto —</option>
      {proyectos.map((p) => (
        <option value={p.id} selected={p.id === servicio?.proyectoId}>{p.titulo}</option>
      ))}
    </select>
    {proyectos.length === 0 && (
      <p class="text-xs text-amber-300 mt-1">⚠ No hay proyectos. <a href="/admin/proyectos/nuevo" class="underline">Crea uno primero</a>.</p>
    )}
  </div>

  <div class="grid sm:grid-cols-2 gap-4">
    <div>
      <label class="etiqueta" for="tipo">Tipo *</label>
      <select id="tipo" name="tipo" required class="input">
        {tipos.map((t) => (
          <option value={t.v} selected={servicio?.tipo === t.v}>{t.l}</option>
        ))}
      </select>
    </div>
    <div>
      <label class="etiqueta" for="precio">Precio (€) *</label>
      <input id="precio" name="precio" type="number" min="0" step="0.01" required class="input" value={servicio?.precio ?? ''} placeholder="2500.00" />
    </div>
  </div>

  <div>
    <label class="etiqueta" for="nombre">Nombre del servicio *</label>
    <input id="nombre" name="nombre" required class="input" maxlength="200" value={servicio?.nombre ?? ''} placeholder="Mantenimiento mensual" />
  </div>

  <div>
    <label class="etiqueta" for="descripcion">Descripción</label>
    <textarea id="descripcion" name="descripcion" rows="3" class="input resize-none">{servicio?.descripcion ?? ''}</textarea>
  </div>

  <div class="grid sm:grid-cols-2 gap-4 items-end">
    <div class="flex items-center justify-between p-3 rounded-lg border border-carbon-700 bg-carbon-900">
      <div>
        <div class="text-sm font-medium text-white">Servicio recurrente</div>
        <div class="text-xs text-carbon-400 mt-0.5">Se factura periódicamente</div>
      </div>
      <label class="relative inline-flex items-center cursor-pointer">
        <input type="checkbox" id="recurrente" name="recurrente" class="sr-only peer" checked={servicio?.recurrente ?? false} />
        <div class="w-11 h-6 bg-carbon-700 rounded-full peer-checked:bg-violeta-600 transition-colors relative after:content-[''] after:absolute after:top-0.5 after:left-0.5 after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-transform peer-checked:after:translate-x-5"></div>
      </label>
    </div>
    <div>
      <label class="etiqueta" for="periodoMeses">Periodo (meses)</label>
      <input id="periodoMeses" name="periodoMeses" type="number" min="1" step="1" class="input" value={servicio?.periodoMeses ?? ''} placeholder="1 = mensual, 12 = anual" />
    </div>
  </div>

  <div id="estado-formulario" class="hidden"></div>

  <div class="flex items-center justify-between pt-4 border-t border-carbon-800">
    <a href="/admin/servicios" class="btn-fantasma">← Cancelar</a>
    <button type="submit" class="btn-primario">
      {modo === 'crear' ? 'Crear servicio' : 'Guardar cambios'}
    </button>
  </div>
</form>

<script>
  const form = document.getElementById('formulario-servicio') as HTMLFormElement;
  const estado = document.getElementById('estado-formulario') as HTMLDivElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const datos: any = Object.fromEntries(new FormData(form).entries());
    datos.recurrente = (form.querySelector('#recurrente') as HTMLInputElement).checked;
    if (!datos.descripcion) datos.descripcion = null;
    if (!datos.periodoMeses) datos.periodoMeses = null;
    estado.className = 'hidden';

    try {
      const res = await fetch(form.dataset.accion!, {
        method: form.dataset.metodo!,
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(datos),
      });
      if (!res.ok) {
        const json = await res.json().catch(() => ({}));
        throw new Error(json.error || 'Error al guardar');
      }
      location.href = '/admin/servicios';
    } catch (err: any) {
      estado.className = 'rounded-lg bg-red-500/10 border border-red-500/30 text-red-300 p-3 text-sm';
      estado.textContent = '✗ ' + err.message;
    }
  });
</script>
