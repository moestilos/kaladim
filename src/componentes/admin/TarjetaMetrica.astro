---
interface Props {
  etiqueta: string;
  valor: string | number;
  tendencia?: string;
  positiva?: boolean;
  icono?: 'ingresos' | 'clientes' | 'proyectos' | 'automatizaciones';
}
const { etiqueta, valor, tendencia, positiva = true, icono } = Astro.props;
---

<div class="tarjeta p-6">
  <div class="flex items-start justify-between">
    <div>
      <p class="text-xs uppercase tracking-wider text-carbon-400">{etiqueta}</p>
      <p class="mt-2 text-3xl font-display font-bold text-white">{valor}</p>
    </div>
    <div class="h-10 w-10 rounded-lg bg-violeta-600/15 border border-violeta-500/20 grid place-items-center">
      {icono === 'ingresos' && (
        <svg class="h-5 w-5 text-violeta-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <path d="M12 2v20M17 7H9.5a2.5 2.5 0 000 5h5a2.5 2.5 0 010 5H7" stroke-linecap="round"/>
        </svg>
      )}
      {icono === 'clientes' && (
        <svg class="h-5 w-5 text-violeta-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <circle cx="12" cy="8" r="3.5"/><path d="M4 20c0-4.4 3.6-8 8-8s8 3.6 8 8" stroke-linecap="round"/>
        </svg>
      )}
      {icono === 'proyectos' && (
        <svg class="h-5 w-5 text-violeta-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <path d="M3 7a2 2 0 012-2h4l2 2h8a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V7z"/>
        </svg>
      )}
      {icono === 'automatizaciones' && (
        <svg class="h-5 w-5 text-violeta-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <path d="M13 2L3 14h7l-1 8 10-12h-7l1-8z" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      )}
    </div>
  </div>
  {tendencia && (
    <div class={`mt-4 text-xs font-medium ${positiva ? 'text-emerald-400' : 'text-red-400'}`}>
      {positiva ? '↑' : '↓'} {tendencia}
    </div>
  )}
</div>
