---
// Gráfica visitas — donut de distribución por página + mini-sparkline tendencia.
// Responsive: donut arriba, stats debajo en móvil · side-by-side en desktop.

import { obtenerResumenVisitas, type ResumenVisitas } from '../../lib/utilidades/analiticas';

let resumen: ResumenVisitas | null = null;
let errorMsg: string | null = null;

try {
  if (import.meta.env.DATABASE_URL) {
    resumen = await obtenerResumenVisitas(30);
  } else {
    errorMsg = 'Sin DATABASE_URL — mostrando datos de ejemplo';
    const hoy = new Date();
    const serie = Array.from({ length: 30 }, (_, i) => {
      const d = new Date(hoy);
      d.setDate(d.getDate() - (29 - i));
      const base = 20 + i * 2 + Math.round(Math.random() * 30);
      return { dia: d.toISOString().slice(0, 10), visitas: base, unicos: Math.round(base * 0.72) };
    });
    resumen = {
      serie,
      total: serie.reduce((a, b) => a + b.visitas, 0),
      unicos: serie.reduce((a, b) => a + b.unicos, 0),
      vsAnterior: 18.4,
      topRutas: [
        { ruta: '/', visitas: 412 },
        { ruta: '/#apps', visitas: 187 },
        { ruta: '/#servicios', visitas: 134 },
        { ruta: '/#contacto', visitas: 98 },
        { ruta: '/#automatizaciones', visitas: 56 },
      ],
      topReferrers: [
        { referrer: 'Directo', visitas: 520 },
        { referrer: 'google.com', visitas: 210 },
        { referrer: 'linkedin.com', visitas: 87 },
        { referrer: 'twitter.com', visitas: 42 },
      ],
    };
  }
} catch (e) {
  errorMsg = e instanceof Error ? e.message : 'Error';
}

const formatoNum = new Intl.NumberFormat('es-ES');
const positivo = (resumen?.vsAnterior ?? 0) >= 0;
---

<section class="tarjeta p-4 sm:p-6">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3 mb-5">
    <div class="min-w-0">
      <h2 class="text-lg font-display font-semibold text-white">Visitas</h2>
      <p class="text-xs text-carbon-400 mt-0.5">Distribución por página · 1 visita/persona cada 30 min</p>
    </div>
    <div class="flex items-center gap-1.5 p-1 rounded-lg bg-carbon-900 border border-carbon-800 shrink-0 self-start">
      <button data-rango="7"  class="btn-rango px-2.5 py-1 text-xs rounded text-carbon-400 hover:text-white transition">7d</button>
      <button data-rango="30" class="btn-rango activo px-2.5 py-1 text-xs rounded bg-carbon-800 text-white">30d</button>
      <button data-rango="90" class="btn-rango px-2.5 py-1 text-xs rounded text-carbon-400 hover:text-white transition">90d</button>
    </div>
  </div>

  {errorMsg && (
    <div class="mb-4 rounded-lg border border-amber-500/30 bg-amber-500/10 px-3 py-2 text-xs text-amber-200">
      ⚠ {errorMsg}
    </div>
  )}

  {resumen && (
    <div class="grid lg:grid-cols-[minmax(0,280px)_1fr] gap-6 items-center">
      <!-- ═══ Donut central ═══ -->
      <div class="relative flex justify-center">
        <div class="relative w-full max-w-[280px] aspect-square">
          <svg id="donut-grafica" viewBox="0 0 200 200" class="w-full h-full -rotate-90">
            <!-- Círculo base fondo -->
            <circle cx="100" cy="100" r="72" fill="none" stroke="rgb(var(--acento-900) / 0.15)" stroke-width="28"/>
            <!-- Segmentos inyectados por JS/SSR -->
            <g id="donut-segmentos"></g>
          </svg>

          <!-- Texto centro -->
          <div class="absolute inset-0 flex flex-col items-center justify-center pointer-events-none">
            <div class="text-[10px] uppercase tracking-wider text-carbon-500">Total</div>
            <div id="metrica-total" class="text-3xl sm:text-4xl font-display font-bold text-white tracking-tight leading-none">{formatoNum.format(resumen.total)}</div>
            <div id="metrica-delta" class={`mt-1 text-xs font-mono ${positivo ? 'text-emerald-400' : 'text-red-400'}`}>
              {positivo ? '↑' : '↓'} {Math.abs(resumen.vsAnterior).toFixed(1)}%
            </div>
          </div>
        </div>
      </div>

      <!-- ═══ Stats + leyenda ═══ -->
      <div class="space-y-4">
        <!-- Mini métricas fila -->
        <div class="grid grid-cols-2 gap-2 sm:gap-3">
          <div class="rounded-lg border border-carbon-800 bg-carbon-950/50 p-3">
            <div class="text-[10px] uppercase tracking-wider text-carbon-500">Únicos</div>
            <div class="mt-1 text-xl sm:text-2xl font-display font-bold text-violeta-300 tracking-tight" id="metrica-unicos">{formatoNum.format(resumen.unicos)}</div>
          </div>
          <div class="rounded-lg border border-carbon-800 bg-carbon-950/50 p-3">
            <div class="text-[10px] uppercase tracking-wider text-carbon-500">Media diaria</div>
            <div class="mt-1 text-xl sm:text-2xl font-display font-bold text-white tracking-tight" id="metrica-media">{formatoNum.format(Math.round(resumen.total / Math.max(1, resumen.serie.length)))}</div>
          </div>
        </div>

        <!-- Leyenda donut = top páginas -->
        <div>
          <h3 class="text-xs uppercase tracking-wider text-carbon-500 mb-2">Páginas más visitadas</h3>
          <div id="leyenda-donut" class="space-y-1.5"></div>
        </div>

        <!-- Mini sparkline tendencia -->
        <div>
          <div class="flex items-center justify-between mb-1">
            <h3 class="text-xs uppercase tracking-wider text-carbon-500">Tendencia</h3>
            <span class="text-[10px] font-mono text-carbon-500" id="rango-fechas">
              {resumen.serie[0].dia} → {resumen.serie[resumen.serie.length - 1].dia}
            </span>
          </div>
          <svg id="mini-spark" viewBox="0 0 300 40" preserveAspectRatio="none" class="w-full h-10">
            <defs>
              <linearGradient id="grad-spark" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="rgb(var(--acento-400))" stop-opacity="0.4"/>
                <stop offset="100%" stop-color="rgb(var(--acento-400))" stop-opacity="0"/>
              </linearGradient>
            </defs>
            <path id="spark-area" fill="url(#grad-spark)"/>
            <path id="spark-linea" fill="none" stroke="rgb(var(--acento-400))" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
      </div>
    </div>
  )}

  {resumen && (
    <!-- Top referrers (debajo, full width) -->
    <div class="mt-6 pt-4 border-t border-carbon-800">
      <h3 class="text-xs uppercase tracking-wider text-carbon-500 mb-3">Principales referrers</h3>
      <div id="top-referrers" class="grid sm:grid-cols-2 gap-2">
        {resumen.topReferrers.map((r) => (
          <div class="flex items-center justify-between text-sm gap-2 px-3 py-2 rounded-lg bg-carbon-950/40 border border-carbon-800">
            <span class="text-carbon-300 text-xs truncate">{r.referrer}</span>
            <span class="text-white font-medium tabular-nums shrink-0">{formatoNum.format(r.visitas)}</span>
          </div>
        ))}
      </div>
    </div>
  )}
</section>

<script>
  const fmt = new Intl.NumberFormat('es-ES');
  const fmtFecha = new Intl.DateTimeFormat('es-ES', { day: '2-digit', month: 'short', year: 'numeric' });

  // Paleta de colores para segmentos (ciclada)
  const COLORES_SEG = [
    'rgb(var(--acento-500))',
    'rgb(var(--acento-300))',
    'rgb(var(--acento-700))',
    'rgb(var(--acento-400))',
    'rgb(var(--acento-600))',
    'rgb(var(--acento-200))',
    'rgb(var(--acento-800))',
    'rgb(var(--acento-100))',
  ];

  // Genera path SVG de arco donut (cx=100, cy=100, r=72, stroke-width=28)
  function arcoPath(inicioAng: number, finAng: number): string {
    const r = 72;
    const x1 = 100 + r * Math.cos(inicioAng);
    const y1 = 100 + r * Math.sin(inicioAng);
    const x2 = 100 + r * Math.cos(finAng);
    const y2 = 100 + r * Math.sin(finAng);
    const largeArc = (finAng - inicioAng) > Math.PI ? 1 : 0;
    return `M ${x1.toFixed(2)} ${y1.toFixed(2)} A ${r} ${r} 0 ${largeArc} 1 ${x2.toFixed(2)} ${y2.toFixed(2)}`;
  }

  function renderDonut(topRutas: { ruta: string; visitas: number }[]) {
    const cont = document.getElementById('donut-segmentos')!;
    const leyenda = document.getElementById('leyenda-donut')!;
    const total = topRutas.reduce((a, b) => a + b.visitas, 0);

    if (total === 0) {
      cont.innerHTML = '';
      leyenda.innerHTML = '<div class="text-sm text-carbon-500">Sin datos</div>';
      return;
    }

    // Ordena desc, toma top 6 + agrupa "otros"
    const sorted = [...topRutas].sort((a, b) => b.visitas - a.visitas);
    const top = sorted.slice(0, 6);
    const otros = sorted.slice(6).reduce((a, b) => a + b.visitas, 0);
    const items = otros > 0 ? [...top, { ruta: 'Otros', visitas: otros }] : top;

    const gap = 0.02; // separación angular entre segmentos (rad)
    let angulo = -Math.PI / 2; // arranca arriba

    cont.innerHTML = items.map((item, i) => {
      const porcion = item.visitas / total;
      const arcoTam = porcion * (Math.PI * 2) - gap;
      const inicio = angulo;
      const fin = angulo + arcoTam;
      angulo = fin + gap;
      const color = COLORES_SEG[i % COLORES_SEG.length];
      return `
        <path
          d="${arcoPath(inicio, fin)}"
          fill="none"
          stroke="${color}"
          stroke-width="28"
          stroke-linecap="round"
          data-i="${i}"
          class="seg-donut transition-[stroke-width] duration-200 cursor-pointer hover:opacity-90"
        />`;
    }).join('');

    // Leyenda
    leyenda.innerHTML = items.map((item, i) => {
      const porcion = ((item.visitas / total) * 100).toFixed(1);
      const color = COLORES_SEG[i % COLORES_SEG.length];
      return `
        <div class="flex items-center gap-2 text-sm" data-leyenda-i="${i}">
          <span class="h-2.5 w-2.5 rounded-full shrink-0" style="background:${color}"></span>
          <span class="text-carbon-300 font-mono text-xs truncate flex-1">${item.ruta}</span>
          <span class="text-white font-medium tabular-nums">${fmt.format(item.visitas)}</span>
          <span class="text-carbon-500 text-xs font-mono tabular-nums w-12 text-right">${porcion}%</span>
        </div>
      `;
    }).join('');

    // Hover sobre leyenda → engrosa segmento correspondiente
    leyenda.querySelectorAll<HTMLDivElement>('[data-leyenda-i]').forEach((el) => {
      const idx = el.dataset.leyendaI;
      el.addEventListener('mouseenter', () => {
        document.querySelector<SVGPathElement>(`.seg-donut[data-i="${idx}"]`)?.setAttribute('stroke-width', '34');
      });
      el.addEventListener('mouseleave', () => {
        document.querySelector<SVGPathElement>(`.seg-donut[data-i="${idx}"]`)?.setAttribute('stroke-width', '28');
      });
    });
    // Hover directo sobre segmento resalta en leyenda
    document.querySelectorAll<SVGPathElement>('.seg-donut').forEach((s) => {
      s.addEventListener('mouseenter', () => s.setAttribute('stroke-width', '34'));
      s.addEventListener('mouseleave', () => s.setAttribute('stroke-width', '28'));
    });
  }

  function renderSparkline(serie: { dia: string; visitas: number }[]) {
    if (serie.length < 2) return;
    const max = Math.max(1, ...serie.map((s) => s.visitas));
    const paso = 300 / (serie.length - 1);
    const pts = serie.map((s, i) => {
      const x = i * paso;
      const y = 40 - (s.visitas / max) * 32 - 4;
      return { x, y };
    });
    const d = pts.map((p, i) => `${i === 0 ? 'M' : 'L'} ${p.x.toFixed(1)} ${p.y.toFixed(1)}`).join(' ');
    const dArea = d + ` L 300 40 L 0 40 Z`;
    document.getElementById('spark-linea')!.setAttribute('d', d);
    document.getElementById('spark-area')!.setAttribute('d', dArea);
  }

  // Datos iniciales (SSR los tiene, pero los re-renderizamos para usar colores acento actuales)
  const rutasInit = [
    ...document.querySelectorAll('[data-ruta-init]')
  ]; // fallback vacío, usaremos fetch inicial

  async function cargar(dias: number) {
    try {
      const res = await fetch(`/api/estadisticas/visitas?dias=${dias}`);
      if (!res.ok) return;
      const data = await res.json();
      repintar(data);
    } catch {}
  }

  function repintar(data: any) {
    const positivo = (data.vsAnterior ?? 0) >= 0;
    document.getElementById('metrica-total')!.textContent = fmt.format(data.total);
    const delta = document.getElementById('metrica-delta')!;
    delta.textContent = `${positivo ? '↑' : '↓'} ${Math.abs(data.vsAnterior).toFixed(1)}%`;
    delta.className = `mt-1 text-xs font-mono ${positivo ? 'text-emerald-400' : 'text-red-400'}`;
    document.getElementById('metrica-unicos')!.textContent = fmt.format(data.unicos);
    document.getElementById('metrica-media')!.textContent = fmt.format(Math.round(data.total / Math.max(1, data.serie.length)));

    if (data.serie.length) {
      document.getElementById('rango-fechas')!.textContent = `${data.serie[0].dia} → ${data.serie[data.serie.length - 1].dia}`;
    }

    renderDonut(data.topRutas ?? []);
    renderSparkline(data.serie ?? []);

    // Top referrers
    const cont = document.getElementById('top-referrers');
    if (cont) {
      cont.innerHTML = (data.topReferrers ?? []).map((r: any) => `
        <div class="flex items-center justify-between text-sm gap-2 px-3 py-2 rounded-lg bg-carbon-950/40 border border-carbon-800">
          <span class="text-carbon-300 text-xs truncate">${r.referrer}</span>
          <span class="text-white font-medium tabular-nums shrink-0">${fmt.format(r.visitas)}</span>
        </div>`).join('');
      if (!data.topReferrers?.length) cont.innerHTML = '<div class="text-sm text-carbon-500 col-span-full">Sin datos</div>';
    }
  }

  // Cambio rango
  document.querySelectorAll<HTMLButtonElement>('.btn-rango').forEach((btn) => {
    btn.addEventListener('click', async () => {
      document.querySelectorAll('.btn-rango').forEach((b) => {
        b.classList.remove('activo', 'bg-carbon-800', 'text-white');
        b.classList.add('text-carbon-400');
      });
      btn.classList.add('activo', 'bg-carbon-800', 'text-white');
      btn.classList.remove('text-carbon-400');
      const dias = btn.dataset.rango;
      await cargar(Number(dias));
    });
  });

  // Carga inicial 30d (ya tenemos SSR stats pero repintamos para donut + sparkline)
  cargar(30);

  // Re-render cuando cambia tema (colores CSS vars cambian)
  window.addEventListener('tema-cambiado', () => cargar(Number(document.querySelector<HTMLButtonElement>('.btn-rango.activo')?.dataset.rango ?? 30)));
</script>
