---
import Logo from '../ui/Logo.astro';

interface Props {
  usuario?: {
    name?: string | null;
    email?: string | null;
    image?: string | null;
  };
  rutaActual?: string;
}
const { usuario, rutaActual = '' } = Astro.props;

const items = [
  { href: '/admin', icono: 'dashboard', etiqueta: 'Dashboard' },
  { href: '/admin/clientes', icono: 'usuarios', etiqueta: 'Clientes' },
  { href: '/admin/proyectos', icono: 'carpeta', etiqueta: 'Proyectos' },
  { href: '/admin/servicios', icono: 'caja', etiqueta: 'Servicios' },
  { href: '/admin/apps', icono: 'panel', etiqueta: 'Apps lanzadas' },
  { href: '/admin/kanban', icono: 'tablero', etiqueta: 'Kanban' },
  { href: '/admin/ideas',  icono: 'bombilla', etiqueta: 'Ideario' },
  { href: '/admin/automatizaciones', icono: 'rayo', etiqueta: 'Automatizaciones' },
  { href: '/admin/usuarios', icono: 'escudo', etiqueta: 'Usuarios' },
  { href: '/admin/roles', icono: 'llave', etiqueta: 'Roles y permisos' },
  { href: '/admin/perfil', icono: 'perfil', etiqueta: 'Mi perfil' },
  { href: '/admin/leads', icono: 'bandeja', etiqueta: 'Leads' },
];

function activo(href: string) {
  if (href === '/admin') return rutaActual === '/admin';
  return rutaActual.startsWith(href);
}
---

<!-- Botón hamburger móvil -->
<button
  id="btn-abrir-sidebar"
  type="button"
  aria-label="Abrir menú"
  class="lg:hidden fixed safe-top safe-left z-[60] h-10 w-10 grid place-items-center rounded-lg border border-carbon-700 bg-carbon-900/90 backdrop-blur text-white"
>
  <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
    <path d="M4 6h16M4 12h16M4 18h16" stroke-linecap="round"/>
  </svg>
</button>

<!-- Backdrop móvil -->
<div id="sidebar-backdrop" class="lg:hidden fixed inset-0 z-40 bg-black/60 backdrop-blur-sm hidden"></div>

<aside id="sidebar-admin" class="fixed left-0 top-0 h-screen w-64 border-r border-carbon-800 bg-carbon-950 flex flex-col z-50 transition-transform duration-200 -translate-x-full lg:translate-x-0" style="padding-top: env(safe-area-inset-top, 0); padding-bottom: env(safe-area-inset-bottom, 0)">
  <div class="p-5 border-b border-carbon-800">
    <Logo tamano="sm" />
  </div>

  <nav class="flex-1 p-3 overflow-y-auto">
    <ul class="space-y-1">
      {items.map((i) => (
        <li>
          <a
            href={i.href}
            class={`flex items-center gap-3 px-3 py-2 rounded-lg text-sm transition-colors ${
              activo(i.href)
                ? 'bg-violeta-600/15 text-violeta-300 border border-violeta-500/20'
                : 'text-carbon-400 hover:text-white hover:bg-carbon-900'
            }`}
          >
            <span class="h-5 w-5 shrink-0">
              {i.icono === 'dashboard' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-5 w-5">
                  <rect x="3" y="3" width="7" height="9" rx="1"/><rect x="14" y="3" width="7" height="5" rx="1"/>
                  <rect x="14" y="12" width="7" height="9" rx="1"/><rect x="3" y="16" width="7" height="5" rx="1"/>
                </svg>
              )}
              {i.icono === 'usuarios' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-5 w-5">
                  <circle cx="9" cy="8" r="3.5"/><path d="M2.5 20c0-3.6 2.9-6.5 6.5-6.5s6.5 2.9 6.5 6.5" stroke-linecap="round"/>
                  <circle cx="17" cy="9" r="2.5"/><path d="M21.5 17.5c0-2-1.5-4-4.5-4" stroke-linecap="round"/>
                </svg>
              )}
              {i.icono === 'carpeta' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-5 w-5">
                  <path d="M3 7a2 2 0 012-2h4l2 2h8a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V7z"/>
                </svg>
              )}
              {i.icono === 'caja' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-5 w-5">
                  <path d="M3 8l9-4 9 4v8l-9 4-9-4V8z"/><path d="M3 8l9 4m0 0l9-4m-9 4v8" stroke-linecap="round"/>
                </svg>
              )}
              {i.icono === 'panel' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-5 w-5">
                  <rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 9v12" stroke-linecap="round"/>
                </svg>
              )}
              {i.icono === 'tablero' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-5 w-5">
                  <rect x="3" y="4" width="5" height="16" rx="1"/><rect x="10" y="4" width="5" height="10" rx="1"/><rect x="17" y="4" width="4" height="7" rx="1"/>
                </svg>
              )}
              {i.icono === 'bombilla' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-5 w-5">
                  <path d="M9 18h6M10 22h4M12 2a7 7 0 00-4 12.8c.6.4 1 1.1 1 1.9V17h6v-.3c0-.8.4-1.5 1-1.9A7 7 0 0012 2z" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              )}
              {i.icono === 'rayo' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-5 w-5">
                  <path d="M13 2L3 14h7l-1 8 10-12h-7l1-8z" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              )}
              {i.icono === 'escudo' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-5 w-5">
                  <path d="M12 2l8 3v7c0 5-4 9-8 10-4-1-8-5-8-10V5l8-3z"/>
                </svg>
              )}
              {i.icono === 'perfil' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-5 w-5">
                  <circle cx="12" cy="7" r="4"/><path d="M4 21c0-4.4 3.6-8 8-8s8 3.6 8 8" stroke-linecap="round"/>
                </svg>
              )}
              {i.icono === 'llave' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-5 w-5">
                  <circle cx="7" cy="16" r="4"/>
                  <path d="M10.5 13.5L21 3M18 6l3 3M14 9l3 3" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              )}
              {i.icono === 'bandeja' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-5 w-5">
                  <path d="M3 13l2-8h14l2 8M3 13v7h18v-7M3 13h6l2 2h2l2-2h6"/>
                </svg>
              )}
            </span>
            {i.etiqueta}
          </a>
        </li>
      ))}
    </ul>
  </nav>

  <div class="p-3 border-t border-carbon-800">
    <a href="/admin/perfil" class="flex items-center gap-3 px-2 py-2 rounded-lg hover:bg-carbon-900 transition-colors" title="Ir a mi perfil">
      {usuario?.image ? (
        <img src={usuario.image} alt="" class="h-8 w-8 rounded-full" />
      ) : (
        <div class="h-8 w-8 rounded-full bg-violeta-600 grid place-items-center text-xs text-white font-semibold">
          {usuario?.name?.[0] ?? 'K'}
        </div>
      )}
      <div class="flex-1 min-w-0">
        <div class="text-sm text-white truncate">{usuario?.name ?? 'Admin'}</div>
        <div class="text-xs text-carbon-500 truncate">{usuario?.email ?? ''}</div>
      </div>
    </a>
    <button
      id="boton-salir"
      class="w-full mt-2 flex items-center gap-2 px-3 py-2 rounded-lg text-xs text-carbon-400 hover:text-white hover:bg-carbon-900 transition"
    >
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
        <path d="M15 3h4a2 2 0 012 2v14a2 2 0 01-2 2h-4M10 17l-5-5 5-5M5 12h12" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Cerrar sesión
    </button>
  </div>
</aside>

<script>
  import { signOut } from 'auth-astro/client';
  document.getElementById('boton-salir')?.addEventListener('click', () => signOut({ callbackUrl: '/' }));

  // Toggle sidebar móvil
  const aside = document.getElementById('sidebar-admin');
  const backdrop = document.getElementById('sidebar-backdrop');
  const btnAbrir = document.getElementById('btn-abrir-sidebar');
  function abrir() {
    aside?.classList.remove('-translate-x-full');
    backdrop?.classList.remove('hidden');
  }
  function cerrar() {
    aside?.classList.add('-translate-x-full');
    backdrop?.classList.add('hidden');
  }
  btnAbrir?.addEventListener('click', abrir);
  backdrop?.addEventListener('click', cerrar);
  aside?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => {
    if (window.innerWidth < 1024) cerrar();
  }));
</script>
