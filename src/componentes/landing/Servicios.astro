---
// Servicios principales — grid de 3 columnas con iconos.
const servicios = [
  {
    icono: 'web',
    titulo: 'Desarrollo Web',
    descripcion: 'Webs corporativas, landings y e-commerce con Astro, Next.js o Angular. Optimizadas para SEO y velocidad.',
    caracteristicas: ['Lighthouse 95+', 'Mobile-first', 'SEO técnico', 'CMS a medida'],
    destacado: false,
  },
  {
    icono: 'automatizacion',
    titulo: 'Automatizaciones n8n',
    descripcion: 'Conectamos tus herramientas (CRM, email, Slack, APIs) en flujos que trabajan sin intervención humana.',
    caracteristicas: ['+400 integraciones', 'Self-hosted o cloud', 'Monitorización 24/7', 'Escalable'],
    destacado: true,
  },
  {
    icono: 'api',
    titulo: 'Integraciones API',
    descripcion: 'Conectamos sistemas legacy con servicios modernos. Webhooks, colas, sincronización bidireccional.',
    caracteristicas: ['REST / GraphQL', 'Autenticación OAuth', 'Rate limiting', 'Logs centralizados'],
    destacado: false,
  },
];
---

<section id="servicios" class="seccion relative">
  <div class="contenedor">
    <!-- Encabezado sección -->
    <div class="max-w-2xl">
      <span class="text-sm font-semibold text-violeta-400 uppercase tracking-wider">Lo que hacemos</span>
      <h2 class="mt-3 text-4xl sm:text-5xl font-display font-bold text-white">
        Servicios diseñados para <span class="texto-gradiente">escalar</span>
      </h2>
      <p class="mt-4 text-lg text-carbon-300">
        Desde tu primera landing hasta flujos empresariales complejos. Te acompañamos en cada fase del crecimiento digital.
      </p>
    </div>

    <!-- Grid -->
    <div class="mt-16 grid gap-6 md:grid-cols-3">
      {servicios.map((s) => (
        <article class={`tarjeta-interactiva p-8 ${s.destacado ? 'borde-gradiente brillo-violeta' : ''}`}>
          {s.destacado && (
            <div class="absolute top-4 right-4">
              <span class="badge-info">Popular</span>
            </div>
          )}
          <div class="h-12 w-12 rounded-xl bg-violeta-600/15 grid place-items-center border border-violeta-500/20">
            {s.icono === 'web' && (
              <svg class="h-6 w-6 text-violeta-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <rect x="3" y="4" width="18" height="16" rx="2"/>
                <path d="M3 9h18M7 13h6M7 16h4" stroke-linecap="round"/>
              </svg>
            )}
            {s.icono === 'automatizacion' && (
              <svg class="h-6 w-6 text-violeta-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <circle cx="6" cy="6" r="2.5"/><circle cx="18" cy="6" r="2.5"/>
                <circle cx="6" cy="18" r="2.5"/><circle cx="18" cy="18" r="2.5"/>
                <path d="M8.5 6h7M6 8.5v7M18 8.5v7M8.5 18h7" stroke-linecap="round"/>
              </svg>
            )}
            {s.icono === 'api' && (
              <svg class="h-6 w-6 text-violeta-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <path d="M10 3l-7 9 7 9M14 3l7 9-7 9" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            )}
          </div>

          <h3 class="mt-6 text-xl font-display font-semibold text-white">{s.titulo}</h3>
          <p class="mt-2 text-sm text-carbon-300 leading-relaxed">{s.descripcion}</p>

          <ul class="mt-6 space-y-2">
            {s.caracteristicas.map((c) => (
              <li class="flex items-center gap-2 text-sm text-carbon-200">
                <svg class="h-4 w-4 text-violeta-400 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {c}
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>
