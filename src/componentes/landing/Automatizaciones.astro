---
// Sección visual explicando n8n — flujo animado conectando nodos.
const nodos = [
  { nombre: 'Gmail', color: 'bg-red-500/15 text-red-400 border-red-500/20', icono: '✉' },
  { nombre: 'CRM', color: 'bg-blue-500/15 text-blue-400 border-blue-500/20', icono: '◈' },
  { nombre: 'Slack', color: 'bg-emerald-500/15 text-emerald-400 border-emerald-500/20', icono: '#' },
  { nombre: 'Notion', color: 'bg-amber-500/15 text-amber-400 border-amber-500/20', icono: '◳' },
];

const casosUso = [
  { titulo: 'Leads → CRM automático', descripcion: 'Formulario web envía lead a HubSpot, notifica a Slack y crea tarea en Asana.', ahorro: '~6h/semana' },
  { titulo: 'Facturación recurrente', descripcion: 'Stripe dispara factura, sube PDF a Drive y envía email al cliente.', ahorro: '~4h/semana' },
  { titulo: 'Soporte 24/7', descripcion: 'Ticket entrante se clasifica con IA y se asigna al agente correcto.', ahorro: '~12h/semana' },
  { titulo: 'Reportes semanales', descripcion: 'Extraemos métricas de 5 fuentes, generamos gráfica y enviamos informe.', ahorro: '~3h/semana' },
];
---

<section id="automatizaciones" class="seccion relative overflow-hidden">
  <!-- Fondo decorativo -->
  <div class="absolute inset-0 fondo-grid pointer-events-none opacity-50"></div>

  <div class="contenedor relative">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Columna texto -->
      <div>
        <span class="text-sm font-semibold text-violeta-400 uppercase tracking-wider">Automatizaciones con n8n</span>
        <h2 class="mt-3 text-4xl sm:text-5xl font-display font-bold text-white">
          Tu equipo, <span class="texto-gradiente">multiplicado</span> por automatización.
        </h2>
        <p class="mt-5 text-lg text-carbon-300 leading-relaxed">
          n8n es el motor detrás de nuestras automatizaciones. Conecta cualquier API,
          aplica lógica condicional con IA y escala sin escribir código.
        </p>

        <div class="mt-8 grid sm:grid-cols-2 gap-3">
          {['+400 integraciones nativas', 'Ejecución auto-escalable', 'Código custom cuando hace falta', 'Logs y métricas incluidos'].map((c) => (
            <div class="flex items-center gap-2 text-sm text-carbon-200">
              <div class="h-5 w-5 rounded-full bg-violeta-600/20 grid place-items-center">
                <svg class="h-3 w-3 text-violeta-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                  <path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              {c}
            </div>
          ))}
        </div>

        <a href="#contacto" class="btn-primario mt-10">
          Automatizar mi empresa
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>

      <!-- Columna visual: diagrama de flujo -->
      <div class="relative">
        <div class="tarjeta-glass p-8 brillo-violeta">
          <div class="text-xs font-mono text-carbon-400 mb-6 flex items-center gap-2">
            <span class="inline-block h-2 w-2 rounded-full bg-emerald-400 animate-brillar"></span>
            workflow.ejecutando · 0.3s
          </div>

          <div class="space-y-3">
            <!-- Trigger -->
            <div class="relative">
              <div class="tarjeta p-3 flex items-center gap-3 border-violeta-500/40 bg-violeta-500/5">
                <div class="h-8 w-8 rounded-lg bg-violeta-600 grid place-items-center text-white text-sm font-bold">T</div>
                <div>
                  <div class="text-sm font-medium text-white">Trigger: Webhook</div>
                  <div class="text-xs text-carbon-400">Nuevo formulario recibido</div>
                </div>
              </div>
            </div>

            <!-- Línea conectora -->
            <div class="ml-4 h-6 w-px bg-gradient-to-b from-violeta-500 to-carbon-700 relative">
              <div class="absolute inset-x-0 top-0 h-2 w-px bg-violeta-400 animate-pulse"></div>
            </div>

            <!-- Nodos en paralelo -->
            <div class="grid grid-cols-2 gap-3">
              {nodos.map((n) => (
                <div class={`tarjeta p-3 border ${n.color} transition-all hover:-translate-y-0.5`}>
                  <div class="flex items-center gap-2">
                    <span class="text-lg">{n.icono}</span>
                    <span class="text-sm font-medium">{n.nombre}</span>
                  </div>
                </div>
              ))}
            </div>

            <div class="ml-4 h-6 w-px bg-gradient-to-b from-carbon-700 to-emerald-500"></div>

            <!-- Salida -->
            <div class="tarjeta p-3 flex items-center gap-3 border-emerald-500/30 bg-emerald-500/5">
              <div class="h-8 w-8 rounded-lg bg-emerald-600 grid place-items-center text-white text-sm">✓</div>
              <div>
                <div class="text-sm font-medium text-white">Completado</div>
                <div class="text-xs text-carbon-400">4 acciones ejecutadas</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Badges flotantes -->
        <div class="absolute -top-3 -right-3 badge-exito">● En vivo</div>
      </div>
    </div>

    <!-- Casos de uso -->
    <div class="mt-24">
      <h3 class="text-center text-2xl font-display font-semibold text-white">Casos de uso reales</h3>
      <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {casosUso.map((c) => (
          <div class="tarjeta-interactiva p-6">
            <div class="text-xs font-mono text-violeta-400 mb-2">{c.ahorro}</div>
            <h4 class="font-semibold text-white">{c.titulo}</h4>
            <p class="mt-2 text-sm text-carbon-400">{c.descripcion}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
