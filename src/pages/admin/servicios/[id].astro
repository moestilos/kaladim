---
import LayoutAdmin from '../../../layouts/LayoutAdmin.astro';
import EncabezadoSeccion from '../../../componentes/admin/EncabezadoSeccion.astro';
import FormularioServicio from '../../../componentes/admin/FormularioServicio.astro';
import { db, esquema } from '../../../lib/db/cliente';
import { eq } from 'drizzle-orm';

export const prerender = false;

const { id } = Astro.params;
if (!id) return Astro.redirect('/admin/servicios');

let servicio: any = null;
try {
  if (import.meta.env.DATABASE_URL) {
    const [f] = await db.select().from(esquema.serviciosContratados).where(eq(esquema.serviciosContratados.id, id));
    servicio = f;
  }
} catch (e) { console.error(e); }
if (!servicio) return Astro.redirect('/admin/servicios');
---
<LayoutAdmin titulo={`Editar · ${servicio.nombre}`}>
  <EncabezadoSeccion titulo="Editar servicio" descripcion={servicio.nombre} />
  <FormularioServicio modo="editar" servicio={servicio} />
</LayoutAdmin>
