---
import LayoutAdmin from '../../../layouts/LayoutAdmin.astro';
import EncabezadoSeccion from '../../../componentes/admin/EncabezadoSeccion.astro';
import TablaDatos from '../../../componentes/admin/TablaDatos.astro';
import { db, esquema } from '../../../lib/db/cliente';
import { desc } from 'drizzle-orm';

export const prerender = false;

let filas: any[] = [];
let error: string | null = null;
try {
  if (import.meta.env.DATABASE_URL) {
    filas = await db.select().from(esquema.serviciosContratados).orderBy(desc(esquema.serviciosContratados.creadoEn));
  } else {
    error = 'Sin DATABASE_URL — ejemplo';
    filas = [
      { id: 's1', nombre: 'Web corporativa completa', tipo: 'web_corporativa', precio: '4500.00', recurrente: false },
      { id: 's2', nombre: 'Mantenimiento mensual', tipo: 'mantenimiento', precio: '250.00', recurrente: true },
    ];
  }
} catch (e) { error = e instanceof Error ? e.message : 'Error'; }

const columnas = [
  { clave: 'nombre', etiqueta: 'Servicio' },
  { clave: 'tipo', etiqueta: 'Tipo' },
  { clave: 'precio', etiqueta: 'Precio', formato: 'moneda' as const },
  { clave: 'recurrente', etiqueta: 'Recurrente' },
];
---
<LayoutAdmin titulo="Servicios contratados">
  <EncabezadoSeccion titulo="Servicios" descripcion="Servicios vinculados a proyectos" hrefNuevo="/admin/servicios/nuevo" textoNuevo="Nuevo servicio" />
  {error && <div class="mb-4 rounded-lg border border-amber-500/30 bg-amber-500/10 px-4 py-2 text-sm text-amber-200">⚠ {error}</div>}
  <TablaDatos columnas={columnas} filas={filas} mensajeVacio="Sin servicios todavía." />
</LayoutAdmin>
