---
import LayoutAdmin from '../../../layouts/LayoutAdmin.astro';
import EncabezadoSeccion from '../../../componentes/admin/EncabezadoSeccion.astro';
import TablaDatos from '../../../componentes/admin/TablaDatos.astro';
import { db, esquema } from '../../../lib/db/cliente';
import { desc } from 'drizzle-orm';

export const prerender = false;

let filas: any[] = [];
let error: string | null = null;
try {
  if (import.meta.env.DATABASE_URL) {
    filas = await db.select().from(esquema.leads).orderBy(desc(esquema.leads.creadoEn));
  } else {
    error = 'Sin DATABASE_URL — ejemplo';
    filas = [
      { id: 'l1', nombre: 'María López', email: 'maria@tech.com', empresa: 'Tech Corp', procesado: false, creadoEn: new Date() },
    ];
  }
} catch (e) { error = e instanceof Error ? e.message : 'Error'; }

const columnas = [
  { clave: 'nombre', etiqueta: 'Nombre' },
  { clave: 'email', etiqueta: 'Email' },
  { clave: 'empresa', etiqueta: 'Empresa' },
  { clave: 'procesado', etiqueta: 'Procesado' },
  { clave: 'creadoEn', etiqueta: 'Recibido', formato: 'fecha' as const },
];
---
<LayoutAdmin titulo="Leads" subtitulo="Capturados desde la web pública">
  <EncabezadoSeccion titulo="Pipeline de leads" />
  {error && <div class="mb-4 rounded-lg border border-amber-500/30 bg-amber-500/10 px-4 py-2 text-sm text-amber-200">⚠ {error}</div>}
  <TablaDatos columnas={columnas} filas={filas} mensajeVacio="Sin leads. Comparte la web para empezar." />
</LayoutAdmin>
