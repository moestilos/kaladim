---
import LayoutAdmin from '../../../layouts/LayoutAdmin.astro';
import EncabezadoSeccion from '../../../componentes/admin/EncabezadoSeccion.astro';
import TablaDatos from '../../../componentes/admin/TablaDatos.astro';
import { db, esquema } from '../../../lib/db/cliente';
import { asc } from 'drizzle-orm';

export const prerender = false;

let filas: any[] = [];
let error: string | null = null;
try {
  if (import.meta.env.DATABASE_URL) {
    filas = await db.select().from(esquema.apps).orderBy(asc(esquema.apps.orden));
  } else {
    error = 'Sin DATABASE_URL — ejemplo';
    filas = [
      { id: 'demo-1', slug: 'moepdf', titulo: 'MoePDF', categoria: 'SaaS', anio: '2026', activo: true, orden: 1 },
    ];
  }
} catch (e) { error = e instanceof Error ? e.message : 'Error'; }

const columnas = [
  { clave: 'orden', etiqueta: '#' },
  { clave: 'titulo', etiqueta: 'Proyecto' },
  { clave: 'slug', etiqueta: 'Slug' },
  { clave: 'categoria', etiqueta: 'Categoría' },
  { clave: 'anio', etiqueta: 'Año' },
  { clave: 'activo', etiqueta: 'Activo' },
];
---
<LayoutAdmin titulo="Apps lanzadas" subtitulo="Portfolio visible en la landing">
  <EncabezadoSeccion
    titulo="Apps lanzadas"
    descripcion={`${filas.length} apps · visibles en /#apps de la web`}
    hrefNuevo="/admin/apps/nuevo"
    textoNuevo="Nueva app"
  />
  {error && <div class="mb-4 rounded-lg border border-amber-500/30 bg-amber-500/10 px-4 py-2 text-sm text-amber-200">⚠ {error}</div>}
  <TablaDatos
    columnas={columnas}
    filas={filas}
    rutaEditar={(f) => `/admin/apps/${f.id}`}
    rutaEliminar="/api/apps"
    mensajeVacio="Sin apps todavía. Añade la primera para empezar a llenar tu portfolio."
    placeholderBusqueda="Buscar por título, slug, categoría..."
  />
</LayoutAdmin>
