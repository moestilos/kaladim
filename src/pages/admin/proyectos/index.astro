---
import LayoutAdmin from '../../../layouts/LayoutAdmin.astro';
import EncabezadoSeccion from '../../../componentes/admin/EncabezadoSeccion.astro';
import TablaDatos from '../../../componentes/admin/TablaDatos.astro';
import { db, esquema } from '../../../lib/db/cliente';
import { desc } from 'drizzle-orm';

export const prerender = false;

let filas: any[] = [];
let error: string | null = null;
try {
  if (import.meta.env.DATABASE_URL) {
    filas = await db.select().from(esquema.proyectos).orderBy(desc(esquema.proyectos.creadoEn));
  } else {
    error = 'Sin DATABASE_URL — ejemplo';
    filas = [
      { id: 'p1', titulo: 'Web corporativa Acme', estado: 'en_progreso', progreso: 65, presupuesto: '4500.00', creadoEn: new Date() },
      { id: 'p2', titulo: 'Automatización facturación', estado: 'completado', progreso: 100, presupuesto: '2200.00', creadoEn: new Date() },
    ];
  }
} catch (e) { error = e instanceof Error ? e.message : 'Error'; }

const columnas = [
  { clave: 'titulo', etiqueta: 'Proyecto' },
  { clave: 'estado', etiqueta: 'Estado' },
  { clave: 'progreso', etiqueta: 'Progreso' },
  { clave: 'presupuesto', etiqueta: 'Presupuesto', formato: 'moneda' as const },
  { clave: 'creadoEn', etiqueta: 'Creado', formato: 'fecha' as const },
];
---
<LayoutAdmin titulo="Proyectos" subtitulo="Seguimiento de entregables">
  <EncabezadoSeccion titulo="Proyectos" hrefNuevo="/admin/proyectos/nuevo" textoNuevo="Nuevo proyecto" />
  {error && <div class="mb-4 rounded-lg border border-amber-500/30 bg-amber-500/10 px-4 py-2 text-sm text-amber-200">⚠ {error}</div>}
  <TablaDatos columnas={columnas} filas={filas} mensajeVacio="Sin proyectos. Crea el primero." />

  <div class="mt-6 tarjeta p-6 border-dashed border-violeta-500/30">
    <p class="text-sm text-carbon-300">
      🛠 <strong>CRUD completo de proyectos:</strong> usa <code class="text-violeta-300 font-mono text-xs">/admin/clientes</code> como plantilla.
      Replica <code class="text-violeta-300 font-mono text-xs">FormularioCliente.astro</code> →
      <code class="text-violeta-300 font-mono text-xs">FormularioProyecto.astro</code> y las rutas API equivalentes.
    </p>
  </div>
</LayoutAdmin>
