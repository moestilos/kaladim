---
import LayoutAdmin from '../../../layouts/LayoutAdmin.astro';
import EncabezadoSeccion from '../../../componentes/admin/EncabezadoSeccion.astro';
import FormularioCaso from '../../../componentes/admin/FormularioCaso.astro';
import { db, esquema } from '../../../lib/db/cliente';
import { eq } from 'drizzle-orm';

export const prerender = false;

const { id } = Astro.params;
if (!id) return Astro.redirect('/admin/casos');

let caso: any = null;
try {
  if (import.meta.env.DATABASE_URL) {
    const [f] = await db.select().from(esquema.casosEstudio).where(eq(esquema.casosEstudio.id, id));
    caso = f;
  }
} catch (e) { console.error(e); }
if (!caso) return Astro.redirect('/admin/casos');
---
<LayoutAdmin titulo={`Editar · ${caso.titulo}`}>
  <EncabezadoSeccion titulo="Editar caso" descripcion={caso.titulo} />
  <FormularioCaso modo="editar" caso={caso} />
</LayoutAdmin>
