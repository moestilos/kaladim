---
import LayoutAdmin from '../../../layouts/LayoutAdmin.astro';
import EncabezadoSeccion from '../../../componentes/admin/EncabezadoSeccion.astro';
import { db, esquema } from '../../../lib/db/cliente';
import { asc, desc } from 'drizzle-orm';
import { asegurarRolesSistema } from '../../../lib/utilidades/permisos';

export const prerender = false;

let filas: any[] = [];
let rolesDisponibles: { slug: string; nombre: string; color: string; temporal?: boolean; duracionDiasPorDefecto?: number }[] = [];
let asignaciones: { usuarioId: string; rolSlug: string; expiraEn: Date | null }[] = [];
let error: string | null = null;
try {
  if (import.meta.env.DATABASE_URL) {
    await asegurarRolesSistema();
    filas = await db.select().from(esquema.usuarios).orderBy(desc(esquema.usuarios.creadoEn));
    rolesDisponibles = await db
      .select({
        slug: esquema.roles.slug,
        nombre: esquema.roles.nombre,
        color: esquema.roles.color,
        temporal: esquema.roles.temporal,
        duracionDiasPorDefecto: esquema.roles.duracionDiasPorDefecto,
      })
      .from(esquema.roles)
      .orderBy(asc(esquema.roles.orden), asc(esquema.roles.nombre));

    // Todas las asignaciones no expiradas
    const { and, gt, isNull, or } = await import('drizzle-orm');
    asignaciones = await db.select({
      usuarioId: esquema.usuarioRoles.usuarioId,
      rolSlug: esquema.usuarioRoles.rolSlug,
      expiraEn: esquema.usuarioRoles.expiraEn,
    }).from(esquema.usuarioRoles).where(or(
      isNull(esquema.usuarioRoles.expiraEn),
      gt(esquema.usuarioRoles.expiraEn, new Date()),
    ));
  } else {
    error = 'Sin DATABASE_URL — ejemplo';
    filas = [
      { id: 'u1', nombre: 'Admin Demo', email: 'admin@kaladim.com', rol: 'admin', activo: true, avatarUrl: null, creadoEn: new Date() },
    ];
    rolesDisponibles = [
      { slug: 'admin', nombre: 'Administrador', color: 'violeta' },
      { slug: 'editor', nombre: 'Editor', color: 'emerald' },
      { slug: 'viewer', nombre: 'Lector', color: 'cyan' },
      { slug: 'cliente', nombre: 'Cliente', color: 'carbon' },
    ];
  }
} catch (e) { error = e instanceof Error ? e.message : 'Error'; }

const rolUsuarioActual = Astro.locals.usuario?.rol ?? 'viewer';
const puedeGestionar = rolUsuarioActual === 'admin';
---

<LayoutAdmin titulo="Usuarios y permisos" subtitulo="Gestión de accesos al panel">
  <EncabezadoSeccion
    titulo="Usuarios"
    descripcion={puedeGestionar ? 'Invita nuevos miembros y asigna su rol. Accederán tras loguearse con Google.' : 'Solo lectura — necesitas rol admin para gestionar.'}
  />

  {error && <div class="mb-4 rounded-lg border border-amber-500/30 bg-amber-500/10 px-4 py-2 text-sm text-amber-200">⚠ {error}</div>}

  <!-- ═══ Acceso rápido roles ═══ -->
  <div class="mb-6 flex items-center justify-between gap-3 flex-wrap">
    <p class="text-sm text-carbon-400">
      Roles disponibles: <span class="text-white font-medium">{rolesDisponibles.length}</span>
    </p>
    <a href="/admin/roles" class="btn-secundario text-sm">
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l8 3v7c0 5-4 9-8 10-4-1-8-5-8-10V5l8-3z" stroke-linecap="round" stroke-linejoin="round"/></svg>
      Gestionar roles y permisos
    </a>
  </div>

  {puedeGestionar && (
    <!-- ═══ Form invitar ═══ -->
    <form id="form-invitar" class="tarjeta p-4 sm:p-6 mb-6">
      <h3 class="text-sm font-semibold text-white mb-4">Invitar usuario</h3>
      <div class="grid sm:grid-cols-[1fr_1fr_180px_auto] gap-3">
        <div>
          <label class="etiqueta" for="inv-email">Email *</label>
          <input id="inv-email" name="email" type="email" required class="input" placeholder="persona@empresa.com" />
        </div>
        <div>
          <label class="etiqueta" for="inv-nombre">Nombre *</label>
          <input id="inv-nombre" name="nombre" required class="input" placeholder="Nombre completo" />
        </div>
        <div>
          <label class="etiqueta" for="inv-rol">Rol</label>
          <select id="inv-rol" name="rol" class="input">
            {rolesDisponibles.map((r) => (
              <option value={r.slug} selected={r.slug === 'viewer'}>{r.nombre}</option>
            ))}
          </select>
        </div>
        <div class="sm:self-end">
          <button type="submit" class="btn-primario w-full">+ Invitar</button>
        </div>
      </div>
      <p class="text-xs text-carbon-500 mt-3">El usuario podrá acceder al loguearse con Google usando este email.</p>
    </form>
  )}

  <!-- ═══ Listado ═══ -->
  <div class="tarjeta overflow-hidden">
    <div class="p-3 sm:p-4 border-b border-carbon-800 flex flex-col sm:flex-row sm:items-center gap-2">
      <div class="relative flex-1 sm:max-w-xs">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-carbon-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M20 20l-3.5-3.5" stroke-linecap="round"/></svg>
        <input id="busqueda-usuarios" type="text" placeholder="Buscar por nombre o email..." class="input pl-9 py-2 text-sm" />
      </div>
      <select id="filtro-rol" class="input py-2 text-sm sm:max-w-[200px]">
        <option value="">Todos los roles</option>
        {rolesDisponibles.map((r) => (
          <option value={r.slug}>{r.nombre}</option>
        ))}
      </select>
      <label class="flex items-center gap-2 text-xs text-carbon-400 whitespace-nowrap px-2">
        <input type="checkbox" id="filtro-inactivos" class="accent-violeta-600" />
        Mostrar inactivos
      </label>
      <span class="text-xs text-carbon-500 sm:ml-auto" id="contador-usuarios">{filas.length}</span>
    </div>

    <div id="lista-usuarios" class="divide-y divide-carbon-800"></div>
  </div>
</LayoutAdmin>

<script id="datos-usuarios" type="application/json" set:html={JSON.stringify({ usuarios: filas, puedeGestionar, roles: rolesDisponibles, asignaciones })}></script>

<script>
  const datos = JSON.parse(document.getElementById('datos-usuarios')!.textContent!);
  let usuarios: any[] = datos.usuarios;
  const puedeGestionar: boolean = datos.puedeGestionar;
  const rolesDisponibles: { slug: string; nombre: string; color: string; temporal?: boolean; duracionDiasPorDefecto?: number }[] = datos.roles ?? [];
  // Mapa usuarioId → [{ rolSlug, expiraEn }]
  let asignaciones: { usuarioId: string; rolSlug: string; expiraEn: string | null }[] = datos.asignaciones ?? [];

  function rolesDeUsuario(uid: string): { slug: string; expiraEn: string | null }[] {
    const slugs = new Set<string>();
    const out: { slug: string; expiraEn: string | null }[] = [];
    asignaciones.filter((a) => a.usuarioId === uid).forEach((a) => {
      if (slugs.has(a.rolSlug)) return;
      slugs.add(a.rolSlug);
      out.push({ slug: a.rolSlug, expiraEn: a.expiraEn });
    });
    return out;
  }

  function diasRestantes(expiraEn: string | null): number | null {
    if (!expiraEn) return null;
    const ms = new Date(expiraEn).getTime() - Date.now();
    return Math.max(0, Math.ceil(ms / (1000 * 60 * 60 * 24)));
  }

  const mapaColor: Record<string, string> = {
    violeta: 'bg-violeta-500/15 text-violeta-300 border-violeta-500/30',
    emerald: 'bg-emerald-500/15 text-emerald-300 border-emerald-500/30',
    cyan: 'bg-cyan-500/15 text-cyan-300 border-cyan-500/30',
    amber: 'bg-amber-500/15 text-amber-300 border-amber-500/30',
    red: 'bg-red-500/15 text-red-300 border-red-500/30',
    rosa: 'bg-pink-500/15 text-pink-300 border-pink-500/30',
    azul: 'bg-blue-500/15 text-blue-300 border-blue-500/30',
    naranja: 'bg-orange-500/15 text-orange-300 border-orange-500/30',
    carbon: 'bg-carbon-800 text-carbon-400 border-carbon-700',
  };
  const rolInfo: Record<string, { nombre: string; color: string }> = {};
  rolesDisponibles.forEach((r) => { rolInfo[r.slug] = { nombre: r.nombre, color: r.color }; });

  function colorRol(slug: string): string {
    const info = rolInfo[slug];
    return mapaColor[info?.color ?? 'carbon'];
  }
  function nombreRol(slug: string): string {
    return rolInfo[slug]?.nombre ?? slug;
  }

  const contador = document.getElementById('contador-usuarios')!;
  const lista = document.getElementById('lista-usuarios')!;
  const busqueda = document.getElementById('busqueda-usuarios') as HTMLInputElement;
  const filtroRol = document.getElementById('filtro-rol') as HTMLSelectElement;
  const filtroInactivos = document.getElementById('filtro-inactivos') as HTMLInputElement;

  function escHtml(s: string): string {
    return String(s ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function pintar() {
    const q = busqueda.value.toLowerCase();
    const rol = filtroRol.value;
    const verInactivos = filtroInactivos.checked;
    const filtrados = usuarios.filter((u) => {
      const coincideBusqueda = (u.nombre + ' ' + u.email).toLowerCase().includes(q);
      const coincideRol = !rol || u.rol === rol;
      const coincideActivo = verInactivos || u.activo !== false;
      return coincideBusqueda && coincideRol && coincideActivo;
    });
    contador.textContent = `${filtrados.length} de ${usuarios.length}`;

    if (filtrados.length === 0) {
      lista.innerHTML = `<div class="p-8 text-center text-sm text-carbon-500">Sin resultados</div>`;
      return;
    }

    const opcionesRol = rolesDisponibles.map((r) =>
      `<option value="${r.slug}">${escHtml(r.nombre)}</option>`
    ).join('');

    lista.innerHTML = filtrados.map((u) => {
      const inicial = (u.nombre?.[0] ?? u.email[0] ?? '?').toUpperCase();
      const avatar = u.avatarUrl
        ? `<img src="${u.avatarUrl}" alt="" class="h-10 w-10 rounded-full ring-1 ring-carbon-700"/>`
        : `<div class="h-10 w-10 rounded-full bg-gradient-to-br from-violeta-500 to-violeta-700 grid place-items-center text-sm font-semibold text-white">${inicial}</div>`;
      const ultimo = u.ultimoAcceso ? new Date(u.ultimoAcceso).toLocaleDateString('es-ES') : 'Nunca';
      const activo = u.activo !== false;

      // Roles multi: el principal (u.rol) + extras de la tabla usuario_roles
      const rolesExtra = rolesDeUsuario(u.id);
      const slugsMostrados = new Set<string>();
      const todos: { slug: string; expiraEn: string | null; principal: boolean }[] = [];
      if (u.rol) { todos.push({ slug: u.rol, expiraEn: null, principal: true }); slugsMostrados.add(u.rol); }
      rolesExtra.forEach((a) => { if (!slugsMostrados.has(a.slug)) { todos.push({ ...a, principal: false }); slugsMostrados.add(a.slug); } });

      const badgesRoles = todos.map((a) => {
        const dias = diasRestantes(a.expiraEn);
        const expira = dias !== null ? ` <span class="ml-1 text-[9px] font-mono opacity-80">⏱${dias}d</span>` : '';
        const btnX = puedeGestionar && !a.principal
          ? `<button class="btn-quitar-rol ml-1 hover:text-red-400" data-uid="${u.id}" data-slug="${a.slug}" title="Quitar rol">×</button>`
          : '';
        return `<span class="badge ${colorRol(a.slug)} text-[10px] inline-flex items-center">${escHtml(nombreRol(a.slug))}${expira}${btnX}</span>`;
      }).join('');

      return `
        <div class="flex flex-col lg:flex-row lg:items-center gap-3 p-4 hover:bg-carbon-900/40 transition" data-id="${u.id}">
          <div class="flex items-center gap-3 flex-1 min-w-0">
            ${avatar}
            <div class="min-w-0 flex-1">
              <div class="flex items-center gap-1.5 flex-wrap">
                <span class="font-medium text-white truncate">${escHtml(u.nombre)}</span>
                ${badgesRoles}
                ${!activo ? '<span class="text-[10px] text-red-400 font-mono">inactivo</span>' : ''}
              </div>
              <div class="text-xs text-carbon-400 truncate">${escHtml(u.email)}</div>
              <div class="text-[10px] text-carbon-500 font-mono mt-0.5">Último acceso: ${ultimo}</div>
            </div>
          </div>
          ${puedeGestionar ? `
            <div class="flex items-center gap-1.5 shrink-0 flex-wrap">
              <button class="btn-anadir-rol btn-secundario text-xs py-1.5 px-2.5" data-uid="${u.id}" ${!activo ? 'disabled' : ''} title="Asignar rol adicional">+ rol</button>
              <select data-sel-rol="${u.id}" class="input py-1.5 text-xs" ${!activo ? 'disabled' : ''} title="Rol principal">
                <option disabled selected>rol principal...</option>
                ${rolesDisponibles.map((r) => `<option value="${r.slug}" ${u.rol === r.slug ? 'selected' : ''}>${escHtml(r.nombre)}</option>`).join('')}
              </select>
              <button data-toggle-activo="${u.id}" class="p-2 rounded hover:bg-carbon-800 text-carbon-400 hover:text-white" title="${activo ? 'Desactivar' : 'Activar'}">
                ${activo
                  ? '<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18.36 6.64A9 9 0 1119 12" stroke-linecap="round"/><line x1="12" y1="2" x2="12" y2="12" stroke-linecap="round"/></svg>'
                  : '<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/></svg>'}
              </button>
              <button data-eliminar="${u.id}" class="p-2 rounded hover:bg-red-500/10 text-carbon-400 hover:text-red-400" title="Eliminar">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M8 6V4a2 2 0 012-2h4a2 2 0 012 2v2M10 11v6M14 11v6M5 6l1 14a2 2 0 002 2h8a2 2 0 002-2l1-14" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </button>
            </div>
          ` : ''}
        </div>`;
    }).join('');

    // Bind eventos
    lista.querySelectorAll<HTMLSelectElement>('[data-sel-rol]').forEach((s) => {
      s.addEventListener('change', async () => {
        const id = s.dataset.selRol!;
        await actualizar(id, { rol: s.value });
      });
    });
    lista.querySelectorAll<HTMLButtonElement>('[data-toggle-activo]').forEach((b) => {
      b.addEventListener('click', async () => {
        const id = b.dataset.toggleActivo!;
        const u = usuarios.find((x) => x.id === id);
        if (!u) return;
        await actualizar(id, { activo: !(u.activo !== false) });
      });
    });
    lista.querySelectorAll<HTMLButtonElement>('[data-eliminar]').forEach((b) => {
      b.addEventListener('click', async () => {
        const id = b.dataset.eliminar!;
        if (!confirm('¿Eliminar usuario? Perderá acceso al panel.')) return;
        await eliminar(id);
      });
    });
    // Añadir rol
    lista.querySelectorAll<HTMLButtonElement>('.btn-anadir-rol').forEach((b) => {
      b.addEventListener('click', () => abrirDialogoAnadirRol(b.dataset.uid!));
    });
    // Quitar rol
    lista.querySelectorAll<HTMLButtonElement>('.btn-quitar-rol').forEach((b) => {
      b.addEventListener('click', async () => {
        const uid = b.dataset.uid!;
        const slug = b.dataset.slug!;
        if (!confirm(`¿Quitar rol '${nombreRol(slug)}' a este usuario?`)) return;
        try {
          const res = await fetch(`/api/usuarios/${uid}/roles?slug=${encodeURIComponent(slug)}`, { method: 'DELETE' });
          if (!res.ok) throw new Error();
          asignaciones = asignaciones.filter((a) => !(a.usuarioId === uid && a.rolSlug === slug));
          pintar();
        } catch { alert('Error al quitar rol'); }
      });
    });
  }

  async function abrirDialogoAnadirRol(uid: string) {
    const rolesExistentes = new Set([
      usuarios.find((u) => u.id === uid)?.rol,
      ...asignaciones.filter((a) => a.usuarioId === uid).map((a) => a.rolSlug),
    ].filter(Boolean));

    const rolesInvitables = rolesDisponibles.filter((r) => !rolesExistentes.has(r.slug));
    if (rolesInvitables.length === 0) { alert('Este usuario ya tiene todos los roles disponibles.'); return; }

    const opciones = rolesInvitables.map((r, i) => `${i + 1}. ${r.nombre}${r.temporal ? ' ⏱ (temporal ' + (r.duracionDiasPorDefecto ?? 7) + 'd)' : ''}`).join('\n');
    const elegido = prompt(`Asignar rol adicional:\n\n${opciones}\n\nEscribe el número:`);
    if (!elegido) return;
    const idx = Number(elegido) - 1;
    const rol = rolesInvitables[idx];
    if (!rol) { alert('Opción inválida'); return; }

    let duracionDias: number | undefined;
    if (rol.temporal) {
      const def = rol.duracionDiasPorDefecto ?? 7;
      const d = prompt(`Duración del acceso en días (default ${def}):`, String(def));
      if (!d) return;
      duracionDias = Math.max(1, Number(d));
    }

    try {
      const res = await fetch(`/api/usuarios/${uid}/roles`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ rolSlug: rol.slug, duracionDias }),
      });
      if (!res.ok) throw new Error();
      const creado = await res.json();
      // Añadir a asignaciones local
      asignaciones.push({ usuarioId: uid, rolSlug: rol.slug, expiraEn: creado.expiraEn });
      pintar();
    } catch { alert('Error al asignar rol'); }
  }

  async function actualizar(id: string, datos: any) {
    try {
      const res = await fetch(`/api/usuarios/${id}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(datos),
      });
      if (!res.ok) throw new Error();
      const act = await res.json();
      usuarios = usuarios.map((u) => u.id === id ? act : u);
      pintar();
    } catch { alert('Error al actualizar'); }
  }

  async function eliminar(id: string) {
    try {
      const res = await fetch(`/api/usuarios/${id}`, { method: 'DELETE' });
      if (!res.ok) throw new Error();
      usuarios = usuarios.filter((u) => u.id !== id);
      pintar();
    } catch { alert('Error al eliminar'); }
  }

  // Form invitar
  const formInv = document.getElementById('form-invitar') as HTMLFormElement | null;
  formInv?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const datos = Object.fromEntries(new FormData(formInv).entries());
    try {
      const res = await fetch('/api/usuarios', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(datos),
      });
      if (!res.ok) throw new Error();
      const u = await res.json();
      // Si ya existía, reemplazar; si no, añadir al inicio
      const idx = usuarios.findIndex((x) => x.email === u.email);
      if (idx >= 0) usuarios[idx] = u;
      else usuarios.unshift(u);
      formInv.reset();
      pintar();
    } catch { alert('Error al invitar'); }
  });

  busqueda.addEventListener('input', pintar);
  filtroRol.addEventListener('change', pintar);
  filtroInactivos.addEventListener('change', pintar);
  pintar();
</script>
