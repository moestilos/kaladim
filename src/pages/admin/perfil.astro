---
import LayoutAdmin from '../../layouts/LayoutAdmin.astro';
import EncabezadoSeccion from '../../componentes/admin/EncabezadoSeccion.astro';
import { db, esquema } from '../../lib/db/cliente';
import { eq } from 'drizzle-orm';

export const prerender = false;

const usuario = Astro.locals.usuario;
const email = usuario?.email ?? '';

let datos: any = {
  email, nombre: usuario?.name ?? '', nombreUsuario: null,
  telefono: null, bio: null, avatarUrl: usuario?.image ?? null,
  rol: usuario?.rol ?? 'viewer', creadoEn: null, ultimoAcceso: null,
};

try {
  if (import.meta.env.DATABASE_URL && email) {
    const [u] = await db.select().from(esquema.usuarios).where(eq(esquema.usuarios.email, email));
    if (u) datos = u;
  }
} catch (e) { console.error('[perfil]', e); }

const rolLabels: Record<string, string> = {
  admin: 'Administrador · acceso total',
  editor: 'Editor · crea y edita',
  viewer: 'Lector · solo ver',
  cliente: 'Cliente',
};
---

<LayoutAdmin titulo="Mi perfil" subtitulo="Tus datos y preferencias">
  <EncabezadoSeccion titulo="Perfil" descripcion="Actualiza tus datos personales. Solo tú puedes verlos y editarlos." />

  <div class="grid gap-6 lg:grid-cols-[1fr_2fr]">
    <!-- Tarjeta resumen -->
    <aside class="tarjeta p-6 h-fit">
      <div class="flex flex-col items-center text-center">
        {datos.avatarUrl
          ? <img src={datos.avatarUrl} alt={datos.nombre} class="h-24 w-24 rounded-full ring-2 ring-violeta-500/30" />
          : <div class="h-24 w-24 rounded-full bg-gradient-to-br from-violeta-500 to-violeta-700 grid place-items-center text-3xl font-display font-bold text-white ring-2 ring-violeta-500/30">{(datos.nombre?.[0] ?? 'U').toUpperCase()}</div>
        }
        <h3 class="mt-4 text-lg font-display font-semibold text-white">{datos.nombre}</h3>
        <p class="text-xs text-carbon-400">{datos.email}</p>
        <span class="mt-3 badge-info text-[10px]">{rolLabels[datos.rol] ?? datos.rol}</span>
      </div>
      <div class="mt-6 pt-6 border-t border-carbon-800 space-y-3 text-xs">
        <div class="flex justify-between">
          <span class="text-carbon-500 uppercase tracking-wider">Alta</span>
          <span class="text-carbon-200 font-mono">{datos.creadoEn ? new Date(datos.creadoEn).toLocaleDateString('es-ES') : '—'}</span>
        </div>
        <div class="flex justify-between">
          <span class="text-carbon-500 uppercase tracking-wider">Último acceso</span>
          <span class="text-carbon-200 font-mono">{datos.ultimoAcceso ? new Date(datos.ultimoAcceso).toLocaleDateString('es-ES') : '—'}</span>
        </div>
      </div>
    </aside>

    <!-- Formulario editar -->
    <form id="form-perfil" class="tarjeta p-6 space-y-5">
      <h3 class="text-sm font-semibold text-white">Datos personales</h3>

      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label class="etiqueta" for="nombre">Nombre completo</label>
          <input id="nombre" name="nombre" class="input" maxlength="120" value={datos.nombre ?? ''} />
        </div>
        <div>
          <label class="etiqueta" for="nombreUsuario">Nombre de usuario</label>
          <input id="nombreUsuario" name="nombreUsuario" class="input font-mono text-sm" maxlength="60" value={datos.nombreUsuario ?? ''} placeholder="@moestilos" />
        </div>
      </div>

      <div>
        <label class="etiqueta" for="email">Email (no editable)</label>
        <input id="email" class="input opacity-60 cursor-not-allowed" value={datos.email} disabled readonly />
      </div>

      <div>
        <label class="etiqueta" for="telefono">Teléfono</label>
        <input id="telefono" name="telefono" type="tel" class="input" maxlength="40" value={datos.telefono ?? ''} placeholder="+34 600 000 000" />
      </div>

      <div>
        <label class="etiqueta">Foto de perfil</label>
        <div class="flex items-center gap-4">
          {/* Preview */}
          <div class="relative shrink-0">
            {datos.avatarUrl
              ? <img id="preview-avatar" src={datos.avatarUrl} alt="" class="h-16 w-16 rounded-full object-cover ring-2 ring-violeta-500/30" />
              : <div id="preview-avatar-placeholder" class="h-16 w-16 rounded-full bg-gradient-to-br from-violeta-500 to-violeta-700 grid place-items-center text-xl font-display font-bold text-white ring-2 ring-violeta-500/30">{(datos.nombre?.[0] ?? 'U').toUpperCase()}</div>
            }
          </div>
          <div class="flex-1 flex flex-col sm:flex-row gap-2">
            <input id="input-archivo" type="file" accept="image/png,image/jpeg,image/webp" class="hidden" />
            <button type="button" id="btn-subir" class="btn-secundario text-sm">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 15V3M7 8l5-5 5 5M4 15v4a2 2 0 002 2h12a2 2 0 002-2v-4" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Subir imagen
            </button>
            <button type="button" id="btn-quitar-avatar" class="btn-fantasma text-sm text-red-400 hover:text-red-300">Quitar</button>
          </div>
        </div>
        <p class="text-[10px] text-carbon-500 mt-2">PNG/JPG/WebP. Máx 5MB. Se redimensiona a 256×256.</p>
        <input type="hidden" id="avatarUrl" name="avatarUrl" value={datos.avatarUrl ?? ''} />
      </div>

      <div>
        <label class="etiqueta" for="bio">Biografía</label>
        <textarea id="bio" name="bio" rows="4" class="input resize-none" maxlength="500" placeholder="Cuéntale al equipo quién eres, qué haces...">{datos.bio ?? ''}</textarea>
        <p class="text-[10px] text-carbon-500 mt-1"><span id="contador-bio">{datos.bio?.length ?? 0}</span> / 500</p>
      </div>

      <div id="estado-perfil" class="hidden"></div>

      <div class="flex justify-end pt-4 border-t border-carbon-800">
        <button type="submit" class="btn-primario">Guardar cambios</button>
      </div>
    </form>
  </div>
</LayoutAdmin>

<script>
  const form = document.getElementById('form-perfil') as HTMLFormElement;
  const estado = document.getElementById('estado-perfil') as HTMLDivElement;
  const bioInput = document.getElementById('bio') as HTMLTextAreaElement;
  const contadorBio = document.getElementById('contador-bio') as HTMLSpanElement;
  bioInput?.addEventListener('input', () => { contadorBio.textContent = String(bioInput.value.length); });

  // ── Upload avatar (redimensionar a 256 + base64) ──
  const btnSubir = document.getElementById('btn-subir') as HTMLButtonElement;
  const btnQuitar = document.getElementById('btn-quitar-avatar') as HTMLButtonElement;
  const inputArchivo = document.getElementById('input-archivo') as HTMLInputElement;
  const avatarUrl = document.getElementById('avatarUrl') as HTMLInputElement;

  function obtenerPreviewEl() {
    return (document.getElementById('preview-avatar') || document.getElementById('preview-avatar-placeholder')) as HTMLElement;
  }

  function reemplazarPreview(src: string | null) {
    const viejo = obtenerPreviewEl();
    if (!viejo) return;
    const padre = viejo.parentElement!;
    viejo.remove();
    if (src) {
      const img = document.createElement('img');
      img.id = 'preview-avatar';
      img.src = src;
      img.alt = '';
      img.className = 'h-16 w-16 rounded-full object-cover ring-2 ring-violeta-500/30';
      padre.appendChild(img);
    } else {
      const div = document.createElement('div');
      div.id = 'preview-avatar-placeholder';
      div.className = 'h-16 w-16 rounded-full bg-gradient-to-br from-violeta-500 to-violeta-700 grid place-items-center text-xl font-display font-bold text-white ring-2 ring-violeta-500/30';
      const nombre = (document.getElementById('nombre') as HTMLInputElement).value;
      div.textContent = (nombre?.[0] ?? 'U').toUpperCase();
      padre.appendChild(div);
    }
  }

  btnSubir.addEventListener('click', () => inputArchivo.click());
  btnQuitar.addEventListener('click', () => {
    avatarUrl.value = '';
    reemplazarPreview(null);
  });

  inputArchivo.addEventListener('change', async (e) => {
    const file = (e.target as HTMLInputElement).files?.[0];
    if (!file) return;
    if (file.size > 5 * 1024 * 1024) { alert('Imagen >5MB'); return; }

    try {
      const dataUrl = await redimensionarImagen(file, 256);
      avatarUrl.value = dataUrl;
      reemplazarPreview(dataUrl);
    } catch (err) {
      alert('Error procesando imagen');
    }
  });

  function redimensionarImagen(file: File, size: number): Promise<string> {
    return new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.onload = () => {
        const img = new Image();
        img.onload = () => {
          const canvas = document.createElement('canvas');
          canvas.width = size;
          canvas.height = size;
          const ctx = canvas.getContext('2d')!;
          // Crop centrado cuadrado + resize
          const lado = Math.min(img.width, img.height);
          const sx = (img.width - lado) / 2;
          const sy = (img.height - lado) / 2;
          ctx.drawImage(img, sx, sy, lado, lado, 0, 0, size, size);
          resolve(canvas.toDataURL('image/webp', 0.85));
        };
        img.onerror = reject;
        img.src = reader.result as string;
      };
      reader.onerror = reject;
      reader.readAsDataURL(file);
    });
  }

  // ── Submit ──
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const datos: any = Object.fromEntries(new FormData(form).entries());
    ['telefono','bio','avatarUrl','nombreUsuario'].forEach((k) => { if (!datos[k]) datos[k] = null; });
    estado.className = 'hidden';
    try {
      const res = await fetch('/api/perfil', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(datos),
      });
      if (!res.ok) {
        const j = await res.json().catch(() => ({}));
        throw new Error(j.error || 'Error');
      }
      estado.className = 'rounded-lg bg-emerald-500/10 border border-emerald-500/30 text-emerald-300 p-3 text-sm';
      estado.textContent = '✓ Perfil actualizado. Recarga para ver el cambio en toda la UI.';
      // Auto-reload 1.2s para que sidebar refleje
      setTimeout(() => location.reload(), 1200);
    } catch (err: any) {
      estado.className = 'rounded-lg bg-red-500/10 border border-red-500/30 text-red-300 p-3 text-sm';
      estado.textContent = '✗ ' + err.message;
    }
  });
</script>
