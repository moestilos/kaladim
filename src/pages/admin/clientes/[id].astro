---
import LayoutAdmin from '../../../layouts/LayoutAdmin.astro';
import EncabezadoSeccion from '../../../componentes/admin/EncabezadoSeccion.astro';
import FormularioCliente from '../../../componentes/admin/FormularioCliente.astro';
import { db, esquema } from '../../../lib/db/cliente';
import { eq } from 'drizzle-orm';

export const prerender = false;

const { id } = Astro.params;
if (!id) return Astro.redirect('/admin/clientes');

let cliente: any = null;
let error: string | null = null;
try {
  if (import.meta.env.DATABASE_URL) {
    const [encontrado] = await db.select().from(esquema.clientes).where(eq(esquema.clientes.id, id));
    cliente = encontrado ?? null;
  } else {
    error = 'Sin DATABASE_URL';
    cliente = { id, empresa: 'Ejemplo', contactoNombre: 'Contacto', contactoEmail: 'test@ejemplo.com' };
  }
} catch (e) {
  error = e instanceof Error ? e.message : 'Error';
}

if (!cliente) return Astro.redirect('/admin/clientes');
---
<LayoutAdmin titulo={`Editar · ${cliente.empresa}`}>
  <EncabezadoSeccion titulo="Editar cliente" descripcion={cliente.empresa} />
  {error && <div class="mb-4 text-sm text-amber-300">⚠ {error}</div>}
  <FormularioCliente modo="editar" cliente={cliente} />
</LayoutAdmin>
