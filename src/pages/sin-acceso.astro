---
import LayoutPublico from '../layouts/LayoutPublico.astro';
---
<LayoutPublico titulo="Sin acceso — Kaladim">
  <section class="min-h-[70vh] grid place-items-center">
    <div class="contenedor text-center">
      <div class="text-6xl">🔒</div>
      <h1 class="mt-6 text-4xl font-display font-bold text-white">Sin permisos suficientes</h1>
      <p class="mt-3 text-carbon-400 max-w-md mx-auto">
        Tu cuenta no tiene rol de administrador. Contacta con el equipo si crees que es un error.
      </p>
      <div class="mt-8 flex gap-3 justify-center">
        <a href="/" class="btn-secundario">Volver al inicio</a>
        <a href="/#contacto" class="btn-primario">Contactar</a>
      </div>
    </div>
  </section>
</LayoutPublico>
